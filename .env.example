# ============================================
# Reporto — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Server ───
NODE_ENV=development
PORT=3000

# ─── MongoDB ───
# Replace with your actual connection string
MONGODB_URI=mongodb://127.0.0.1:27017/Reporto

# ─── Session ───
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# ─── App Branding ───
APP_NAME=Reporto
COMPANY_NAME=Reporto

# ─── Default Admin (used by seed script only) ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@example.com

# ─── Rate Limiting ───
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MS=900000
