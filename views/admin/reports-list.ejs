<!DOCTYPE html>
<html lang="en" data-theme="<%= (typeof adminUser !== 'undefined' && adminUser && adminUser.theme) ? adminUser.theme : 'navy' %>">
<head>
  <script>
    (function(){var t=localStorage.getItem('ag_theme');if(t&&['navy','cyan','amber'].includes(t)){document.documentElement.setAttribute('data-theme',t);if(t==='light')document.documentElement.classList.remove('dark');else document.documentElement.classList.add('dark');}})();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/logo.png">
  <title>Reports — Agile Prime</title>

  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              950: 'var(--surface-950)', 900: 'var(--surface-900)',
              850: 'var(--surface-850)', 800: 'var(--surface-800)',
              700: 'var(--surface-700)',
              gold: 'var(--accent)', 'gold-light': 'var(--accent-light)',
              'gold-dim': 'var(--accent-dim)',
            }
          },
          fontFamily: { sans: ['DM Sans','system-ui','sans-serif'], mono: ['JetBrains Mono','monospace'] }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/app.css">
  <script src="/js/theme.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { background: #080a10; color: #c8cdd6; font-family: 'DM Sans', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 99px; }

    .panel { background: #10151f; border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; }

    /* Filter bar */
    .filter-input {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 9px 14px;
      color: #e2e8f0;
      font-size: 13px;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
    }
    .filter-input:focus { border-color: rgba(201,168,76,0.4); }
    .filter-input option { background: #0f1623; }

    /* Table */
    .report-table { width: 100%; border-collapse: collapse; }
    .report-table thead th {
      padding: 10px 14px;
      font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      text-align: left; white-space: nowrap;
    }
    .report-table tbody tr {
      border-bottom: 1px solid rgba(255,255,255,0.04);
      transition: background 0.15s;
      cursor: pointer;
    }
    .report-table tbody tr:hover { background: rgba(255,255,255,0.025); }
    .report-table tbody tr:last-child { border-bottom: none; }
    .report-table tbody td { padding: 12px 14px; font-size: 13px; }

    .badge {
      display: inline-flex; align-items: center;
      font-size: 10px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;
      padding: 3px 8px; border-radius: 6px;
    }
    .badge-morning { background: rgba(251,191,36,0.12); color: #fbbf24; border: 1px solid rgba(251,191,36,0.2); }
    .badge-day     { background: rgba(99,202,183,0.12);  color: #63cab7; border: 1px solid rgba(99,202,183,0.2); }
    .badge-night   { background: rgba(99,102,241,0.12);  color: #818cf8; border: 1px solid rgba(99,102,241,0.2); }

    .progress-pill {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 11px; font-weight: 700;
      padding: 3px 9px; border-radius: 20px;
    }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 6px;
      background: linear-gradient(135deg, #c9a84c, #e2c97e);
      color: #06080f; font-weight: 700; font-size: 12px;
      padding: 8px 16px; border-radius: 10px; border: none;
      cursor: pointer; transition: opacity 0.2s, transform 0.15s;
      text-decoration: none;
    }
    .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }

    .btn-ghost {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.6); font-size: 12px; font-weight: 500;
      padding: 8px 14px; border-radius: 10px; cursor: pointer;
      transition: background 0.2s, color 0.2s;
      font-family: inherit;
    }
    .btn-ghost:hover { background: rgba(255,255,255,0.07); color: #fff; }

    .stat-card { background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 16px 20px; }
    .stat-val { font-size: 26px; font-weight: 800; font-family: 'JetBrains Mono', monospace; color: #fff; }
    .stat-lbl { font-size: 11px; color: rgba(255,255,255,0.35); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.07em; font-weight: 600; }

    .empty-state { text-align: center; padding: 60px 20px; color: rgba(255,255,255,0.25); }
    .empty-state svg { margin: 0 auto 16px; opacity: 0.2; }

    /* Skeleton loader */
    .skeleton { background: linear-gradient(90deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 100%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 6px; height: 14px; }
    @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }

    /* Pagination */
    .page-btn {
      display: inline-flex; align-items: center; justify-content: center;
      width: 34px; height: 34px; border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      color: rgba(255,255,255,0.5); font-size: 13px; font-weight: 500;
      cursor: pointer; transition: all 0.15s;
    }
    .page-btn:hover:not(:disabled) { background: rgba(255,255,255,0.07); color: #fff; }
    .page-btn.active { background: rgba(201,168,76,0.15); border-color: rgba(201,168,76,0.35); color: #c9a84c; }
    .page-btn:disabled { opacity: 0.3; cursor: not-allowed; }

    .delete-btn {
      background: none; border: none; cursor: pointer;
      color: rgba(239,68,68,0.4); padding: 6px; border-radius: 6px;
      transition: color 0.2s, background 0.2s;
    }
    .delete-btn:hover { color: #ef4444; background: rgba(239,68,68,0.08); }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>

  <main style="padding-top: 76px; min-height: 100vh;">
    <div style="max-width: 1320px; margin: 0 auto; padding: 24px 16px;">

      <!-- Header -->
      <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:24px;">
        <div>
          <h1 style="font-size:22px; font-weight:800; color:#fff; margin:0;">
            <span style="color: var(--accent, #c9a84c);">Site</span> Reports
          </h1>
          <p style="font-size:12px; color:rgba(255,255,255,0.35); margin:4px 0 0;">Browse, search and manage all daily site reports</p>
        </div>
        <div style="display:flex; gap:8px;">
          <button class="btn-ghost" onclick="exportCurrentView()">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Export Excel
          </button>
          <a href="/admin/dashboard" class="btn-ghost" style="text-decoration:none;">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
            </svg>
            Dashboard
          </a>
        </div>
      </div>

      <!-- Stats Row -->
      <div id="statsRow" style="display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:20px;">
        <div class="stat-card">
          <div class="stat-val" id="statTotal">—</div>
          <div class="stat-lbl">Total Reports</div>
        </div>
        <div class="stat-card">
          <div class="stat-val" id="statFiltered" style="color: var(--accent, #c9a84c);">—</div>
          <div class="stat-lbl">Filtered Results</div>
        </div>
        <div class="stat-card">
          <div class="stat-val" id="statEngineers">—</div>
          <div class="stat-lbl">Engineers</div>
        </div>
        <div class="stat-card">
          <div class="stat-val" id="statProjects">—</div>
          <div class="stat-lbl">Projects</div>
        </div>
      </div>

      <!-- Filters Panel -->
      <div class="panel" style="padding:16px 20px; margin-bottom:16px;">
        <div style="display:grid; grid-template-columns:2fr 1fr 1fr 1fr 1fr auto; gap:10px; align-items:end;">

          <div>
            <label style="display:block; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:rgba(255,255,255,0.3); margin-bottom:5px;">Search</label>
            <div style="position:relative;">
              <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);opacity:0.3;" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input type="text" id="filterSearch" class="filter-input" placeholder="Report ID, engineer, site…" style="padding-left:32px;" oninput="scheduleReload()">
            </div>
          </div>

          <div>
            <label style="display:block; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:rgba(255,255,255,0.3); margin-bottom:5px;">Project</label>
            <select id="filterProject" class="filter-input" onchange="applyFilters()">
              <option value="">All Projects</option>
              <% if (typeof filterOptions !== 'undefined' && filterOptions.projects) { %>
                <% filterOptions.projects.forEach(p => { %>
                  <option value="<%= p._id %>"><%= p.name %></option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <div>
            <label style="display:block; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:rgba(255,255,255,0.3); margin-bottom:5px;">Engineer</label>
            <select id="filterEngineer" class="filter-input" onchange="applyFilters()">
              <option value="">All Engineers</option>
              <% if (typeof filterOptions !== 'undefined' && filterOptions.engineers) { %>
                <% filterOptions.engineers.forEach(e => { %>
                  <option value="<%= e._id %>"><%= e.name %></option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <div>
            <label style="display:block; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:rgba(255,255,255,0.3); margin-bottom:5px;">From</label>
            <input type="date" id="filterFrom" class="filter-input" onchange="applyFilters()">
          </div>

          <div>
            <label style="display:block; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:rgba(255,255,255,0.3); margin-bottom:5px;">To</label>
            <input type="date" id="filterTo" class="filter-input" onchange="applyFilters()">
          </div>

          <button class="btn-ghost" onclick="clearFilters()" style="white-space:nowrap; height:38px;">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
            Clear
          </button>
        </div>
      </div>

      <!-- Table Panel -->
      <div class="panel" style="overflow:hidden;">
        <div style="overflow-x:auto;">
          <table class="report-table">
            <thead>
              <tr>
                <th style="width:160px;">Report ID</th>
                <th>Date</th>
                <th>Site / Project</th>
                <th>Engineer</th>
                <th>Shift</th>
                <th>Items</th>
                <th>Manpower</th>
                <th>Progress</th>
                <th style="width:40px;"></th>
              </tr>
            </thead>
            <tbody id="reportsBody">
              <!-- populated by JS -->
            </tbody>
          </table>
        </div>

        <!-- Loading / Empty -->
        <div id="loadingState" style="display:none; padding:40px; text-align:center; color:rgba(255,255,255,0.3);">
          <svg class="spinner" style="width:24px;height:24px;margin:0 auto 12px;display:block;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
          </svg>
          <span style="font-size:13px;">Loading reports…</span>
        </div>

        <div id="emptyState" style="display:none;" class="empty-state">
          <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M9 12h6M9 16h6M9 8h6M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>
          </svg>
          <p style="font-size:15px; font-weight:600; color:rgba(255,255,255,0.2);">No reports found</p>
          <p style="font-size:13px; color:rgba(255,255,255,0.15); margin-top:4px;">Try adjusting your filters</p>
        </div>

        <!-- Pagination -->
        <div id="paginationBar" style="display:none; padding:14px 20px; border-top:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px;">
          <span id="paginationInfo" style="font-size:12px; color:rgba(255,255,255,0.3);"></span>
          <div id="paginationBtns" style="display:flex; gap:4px;"></div>
        </div>
      </div>

    </div>
  </main>

  <!-- Delete Confirm Modal -->
  <div id="deleteModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);align-items:center;justify-content:center;">
    <div style="background:#0c1017;border:1px solid rgba(239,68,68,0.2);border-radius:18px;padding:28px;max-width:420px;width:90%;margin:20px;">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="18" height="18" fill="none" stroke="#ef4444" stroke-width="2" viewBox="0 0 24 24">
            <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/>
          </svg>
        </div>
        <div>
          <h3 style="font-size:16px;font-weight:800;color:#fff;margin:0;">Delete Report?</h3>
          <p style="font-size:12px;color:rgba(255,255,255,0.35);margin:2px 0 0;" id="deleteModalId"></p>
        </div>
      </div>
      <p style="font-size:13px;color:rgba(255,255,255,0.5);margin-bottom:20px;line-height:1.6;">
        This will permanently delete this report and all its work items. <strong style="color:rgba(239,68,68,0.8);">This action cannot be undone.</strong>
      </p>
      <div style="display:flex;gap:10px;">
        <button onclick="closeDeleteModal()" class="btn-ghost" style="flex:1;">Cancel</button>
        <button onclick="executeDelete()" id="deleteConfirmBtn" style="flex:1;background:rgba(239,68,68,0.9);border:none;border-radius:10px;padding:10px;color:#fff;font-weight:700;font-size:13px;cursor:pointer;transition:background 0.2s;" onmouseover="this.style.background='rgba(239,68,68,1)'" onmouseout="this.style.background='rgba(239,68,68,0.9)'">
          Delete Report
        </button>
      </div>
    </div>
  </div>

  <style>
    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner { animation: spin 0.7s linear infinite; }
  </style>

  <script>
    // ── State ──
    let allRows   = [];
    let filteredRows = [];
    const PAGE_SIZE = 25;
    let currentPage = 1;
    let pendingReloadTimer = null;
    let pendingDeleteId = null;
    let canEdit = false;

    // ── Init ──
    document.addEventListener('DOMContentLoaded', () => {
      loadReports();
      checkEditPermission();
    });

    async function checkEditPermission() {
      // Try to fetch a fake report — if 403 we can't edit, if 404 we can
      try {
        const r = await fetch('/api/admin/reports/__perm_check__');
        canEdit = r.status !== 403;
      } catch { canEdit = false; }
    }

    async function loadReports() {
      showLoading(true);
      try {
        const params = new URLSearchParams({
          fromDate:   document.getElementById('filterFrom').value    || '',
          toDate:     document.getElementById('filterTo').value      || '',
          project:    document.getElementById('filterProject').value || '',
          engineer:   document.getElementById('filterEngineer').value || '',
          search:     document.getElementById('filterSearch').value  || '',
        });
        const res = await fetch('/api/admin/dashboard?' + params);
        const data = await res.json();

        if (!data.success) throw new Error(data.error || 'Failed');

        allRows = data.tableRows || [];
        updateStats(data);
        currentPage = 1;
        renderTable();
      } catch (err) {
        console.error(err);
        showEmpty(true);
      } finally {
        showLoading(false);
      }
    }

    function updateStats(data) {
      const engineerSet = new Set(allRows.map(r => r.engineerName));
      const projectSet  = new Set(allRows.map(r => r.siteName));
      document.getElementById('statTotal').textContent    = data.totalCount ?? allRows.length;
      document.getElementById('statFiltered').textContent = allRows.length;
      document.getElementById('statEngineers').textContent = engineerSet.size;
      document.getElementById('statProjects').textContent  = projectSet.size;
    }

    function renderTable() {
      const tbody = document.getElementById('reportsBody');

      if (!allRows.length) {
        tbody.innerHTML = '';
        showEmpty(true);
        document.getElementById('paginationBar').style.display = 'none';
        return;
      }
      showEmpty(false);

      const start  = (currentPage - 1) * PAGE_SIZE;
      const pageRows = allRows.slice(start, start + PAGE_SIZE);

      tbody.innerHTML = pageRows.map((r, i) => {
        const idx = start + i;
        const date = new Date(r.date).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' });
        const shift = (r.shiftType || 'Day');
        const shiftClass = shift === 'Morning' ? 'badge-morning' : shift === 'Night' ? 'badge-night' : 'badge-day';
        const prog = Number(r.averageProgress || 0);
        const progColor = prog >= 80 ? '#22c55e' : prog >= 45 ? '#f59e0b' : '#ef4444';
        const progBg    = prog >= 80 ? 'rgba(34,197,94,0.1)' : prog >= 45 ? 'rgba(245,158,11,0.1)' : 'rgba(239,68,68,0.1)';

        return `<tr onclick="goToReport('${r.reportId}')">
          <td>
            <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--accent,#c9a84c); background:rgba(201,168,76,0.08); padding:3px 8px; border-radius:6px;">
              ${esc(r.reportId)}
            </span>
          </td>
          <td style="color:rgba(255,255,255,0.7); font-size:12.5px; white-space:nowrap;">${date}</td>
          <td>
            <div style="font-size:13px; font-weight:600; color:#e2e8f0;">${esc(r.siteName || '—')}</div>
          </td>
          <td>
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="width:26px;height:26px;border-radius:8px;background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.2);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;color:#c9a84c;flex-shrink:0;">
                ${initials(r.engineerName)}
              </div>
              <span style="font-size:13px;">${esc(r.engineerName || '—')}</span>
            </div>
          </td>
          <td><span class="badge ${shiftClass}">${shift}</span></td>
          <td style="color:rgba(255,255,255,0.6); font-size:12.5px;">${r.itemsCount ?? '—'}</td>
          <td style="font-family:'JetBrains Mono',monospace; font-size:12.5px; color:#e2e8f0;">${r.totalManpower ?? 0}</td>
          <td>
            <span class="progress-pill" style="background:${progBg};color:${progColor};">
              ${prog}%
            </span>
          </td>
          <td onclick="event.stopPropagation()">
            <button class="delete-btn" id="delbtn-${idx}" onclick="openDeleteModal('${esc(r.reportId)}')" title="Delete report" style="display:none;">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/>
              </svg>
            </button>
          </td>
        </tr>`;
      }).join('');

      // Show delete buttons if user has edit permission
      if (canEdit) {
        tbody.querySelectorAll('.delete-btn').forEach(btn => btn.style.display = 'flex');
      }

      renderPagination();
    }

    function renderPagination() {
      const total = allRows.length;
      const pages = Math.ceil(total / PAGE_SIZE);
      const bar   = document.getElementById('paginationBar');

      if (pages <= 1) { bar.style.display = 'none'; return; }
      bar.style.display = 'flex';

      const start = (currentPage - 1) * PAGE_SIZE + 1;
      const end   = Math.min(currentPage * PAGE_SIZE, total);
      document.getElementById('paginationInfo').textContent = `Showing ${start}–${end} of ${total} reports`;

      const btns = document.getElementById('paginationBtns');
      let html = `<button class="page-btn" onclick="goPage(${currentPage-1})" ${currentPage===1?'disabled':''}>‹</button>`;

      // Show limited page range
      const range = 5;
      let pStart = Math.max(1, currentPage - Math.floor(range/2));
      let pEnd   = Math.min(pages, pStart + range - 1);
      if (pEnd - pStart < range - 1) pStart = Math.max(1, pEnd - range + 1);

      if (pStart > 1) html += `<button class="page-btn" onclick="goPage(1)">1</button>${pStart > 2 ? '<span style="color:rgba(255,255,255,0.2);padding:0 4px;">…</span>' : ''}`;
      for (let p = pStart; p <= pEnd; p++) {
        html += `<button class="page-btn ${p===currentPage?'active':''}" onclick="goPage(${p})">${p}</button>`;
      }
      if (pEnd < pages) html += `${pEnd < pages-1 ? '<span style="color:rgba(255,255,255,0.2);padding:0 4px;">…</span>' : ''}<button class="page-btn" onclick="goPage(${pages})">${pages}</button>`;

      html += `<button class="page-btn" onclick="goPage(${currentPage+1})" ${currentPage===pages?'disabled':''}>›</button>`;
      btns.innerHTML = html;
    }

    function goPage(p) {
      const pages = Math.ceil(allRows.length / PAGE_SIZE);
      if (p < 1 || p > pages) return;
      currentPage = p;
      renderTable();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function goToReport(reportId) {
      window.location.href = '/admin/reports/' + reportId;
    }

    // ── Filters ──
    function applyFilters() {
      currentPage = 1;
      loadReports();
    }

    function scheduleReload() {
      clearTimeout(pendingReloadTimer);
      pendingReloadTimer = setTimeout(applyFilters, 400);
    }

    function clearFilters() {
      document.getElementById('filterSearch').value  = '';
      document.getElementById('filterProject').value = '';
      document.getElementById('filterEngineer').value = '';
      document.getElementById('filterFrom').value    = '';
      document.getElementById('filterTo').value      = '';
      applyFilters();
    }

    // ── Delete Modal ──
    function openDeleteModal(reportId) {
      pendingDeleteId = reportId;
      document.getElementById('deleteModalId').textContent = reportId;
      document.getElementById('deleteModal').style.display = 'flex';
    }

    function closeDeleteModal() {
      pendingDeleteId = null;
      document.getElementById('deleteModal').style.display = 'none';
    }

    async function executeDelete() {
      if (!pendingDeleteId) return;
      const btn = document.getElementById('deleteConfirmBtn');
      btn.textContent = 'Deleting…';
      btn.disabled = true;

      try {
        const res = await fetch('/api/admin/reports/' + pendingDeleteId, { method: 'DELETE' });
        const result = await res.json();
        if (!res.ok || !result.success) throw new Error(result.error || 'Failed');
        closeDeleteModal();
        await loadReports();
      } catch (err) {
        alert('Error: ' + err.message);
        btn.textContent = 'Delete Report';
        btn.disabled = false;
      }
    }

    // ── Export ──
    function exportCurrentView() {
      const params = new URLSearchParams({
        fromDate:  document.getElementById('filterFrom').value    || '',
        toDate:    document.getElementById('filterTo').value      || '',
        project:   document.getElementById('filterProject').value || '',
        engineer:  document.getElementById('filterEngineer').value || '',
        search:    document.getElementById('filterSearch').value  || '',
      });
      window.location.href = '/api/admin/export/excel?' + params;
    }

    // ── UI Helpers ──
    function showLoading(show) {
      document.getElementById('loadingState').style.display = show ? 'block' : 'none';
      document.getElementById('reportsBody').style.opacity  = show ? '0.4' : '1';
    }
    function showEmpty(show) {
      document.getElementById('emptyState').style.display = show ? 'block' : 'none';
    }
    function initials(name) {
      return (name || '?').split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
    }
    function esc(s) {
      const d = document.createElement('div');
      d.textContent = String(s || '');
      return d.innerHTML;
    }

    // Close modal on backdrop click
    document.getElementById('deleteModal').addEventListener('click', function(e) {
      if (e.target === this) closeDeleteModal();
    });
  </script>
</body>
</html>
