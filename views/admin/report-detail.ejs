    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-bottom: 20px;
  }

  .stat-card {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
    background: rgba(16,23,38,0.92);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 18px;
    box-shadow: 0 14px 36px rgba(0,0,0,0.18);
