    .wi-status { display: inline-flex !important; min-height: 18px !important; padding: 0 6px !important; font-size: 6.5pt !important; font-weight: 800 !important; margin-bottom: 2px !important; border-radius: 999px !important; border: 1px solid #ccc !important; background: #f4f4f4 !important; color: #555 !important; }

    .work-item[data-status="on-track"] .wi-status        { color: #16a34a !important; border-color: #86efac !important; background: #f0fdf4 !important; }
