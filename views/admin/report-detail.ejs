    .work-item[data-status="in-progress"] .wi-pct     { color: #d97706 !important; -webkit-text-fill-color: #d97706 !important; }
    .work-item[data-status="needs-attention"] .wi-pct { color: #dc2626 !important; -webkit-text-fill-color: #dc2626 !important; }

