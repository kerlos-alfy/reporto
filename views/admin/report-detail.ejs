  body {
    margin: 0;
    color: var(--text);
    font-family: 'DM Sans', Arial, sans-serif;
    background:
      radial-gradient(circle at top left, rgba(201,168,76,0.08), transparent 28%),
      radial-gradient(circle at top right, rgba(59,130,246,0.05), transparent 24%),
      linear-gradient(180deg, #06080f 0%, #0a0f1a 100%);
  }

  .page {
    max-width: 1260px;
    margin: 0 auto;
    padding: var(--nav-offset) 20px 56px;
  }

  .top-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .top-actions-left,
  .top-actions-right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .ghost-btn,
  .print-btn,
  .chip-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 42px;
    padding: 0 14px;
    border-radius: 12px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: 0.22s ease;
    border: 1px solid var(--border);
    cursor: pointer;
    white-space: nowrap;
  }

  .ghost-btn {
    background: rgba(255,255,255,0.03);
    color: rgba(255,255,255,0.72);
  }

  .ghost-btn:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.16);
    background: rgba(255,255,255,0.06);
  }

  .chip-btn {
    background: var(--gold-soft);
    color: var(--gold);
    border-color: var(--gold-border);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    text-transform: none;
    letter-spacing: 0.03em;
  }

  .print-btn {
    color: #0b1120;
    background: linear-gradient(180deg, #e5c46b 0%, #c9a84c 100%);
    border-color: rgba(201,168,76,0.5);
    box-shadow: 0 10px 24px rgba(201,168,76,0.22);
  }

  .print-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 28px rgba(201,168,76,0.28);
  }

  .hero {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    background:
      linear-gradient(135deg, rgba(201,168,76,0.13), rgba(201,168,76,0.03) 28%, rgba(255,255,255,0.02) 100%),
      rgba(10,15,26,0.94);
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 24px 70px rgba(0,0,0,0.28);
