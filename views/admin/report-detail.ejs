<link rel="icon" type="image/png" sizes="16x16" href="/assets/images/logo.png">
<link rel="apple-touch-icon" href="/assets/images/logo.png">
  <title><%= report.reportId %> — Report Detail</title>

  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              950: 'var(--surface-950)',
              900: 'var(--surface-900)',
              850: 'var(--surface-850)',
              800: 'var(--surface-800)',
              750: 'var(--surface-800)',
              700: 'var(--surface-700)',
              600: 'var(--surface-700)',
              500: 'var(--surface-700)',
              gold:         'var(--accent)',
              'gold-light': 'var(--accent-light)',
              'gold-dim':   'var(--accent-dim)',
              'gold-glow':  'var(--accent-a08)',
              'gold-border':'var(--accent-a15)',
            }
          },
          fontFamily: {
            sans: ['DM Sans', 'system-ui', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace']
          }
        }
      }
    }
  </script>

<style>
  * { box-sizing: border-box; }

  :root {
    --bg: #06080f;
    --bg-2: #0a0f1a;
    --card: rgba(16, 23, 38, 0.92);
    --card-2: rgba(255,255,255,0.03);
    --border: rgba(255,255,255,0.08);
    --border-strong: rgba(255,255,255,0.14);
    --text: #f8fafc;
    --muted: rgba(255,255,255,0.64);
    --muted-2: rgba(255,255,255,0.42);
    --muted-3: rgba(255,255,255,0.22);
    --gold: #c9a84c;
    --gold-soft: rgba(201,168,76,0.14);
    --gold-border: rgba(201,168,76,0.22);
    --nav-offset: 108px;
    --radius-xl: 28px;
    --radius-lg: 22px;
    --radius-md: 18px;
    --radius-sm: 14px;
  }

