  .mp-val {
    font-size: 22px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: #fff;
  }

  .mp-key {
    margin-top: 6px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.30);
    line-height: 1.4;
    word-break: break-word;
  }

  .inline-note,
  .scope-note {
    margin-top: 12px;
    padding: 12px 14px;
    border-radius: 14px;
    font-size: 12px;
    line-height: 1.75;
    overflow-wrap: break-word;
  }

  .inline-note {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.62);
  }

  .scope-note {
    background: rgba(59,130,246,0.08);
    border: 1px solid rgba(59,130,246,0.16);
    color: rgba(186,230,253,0.92);
  }

  .side-stack {
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: sticky;
    top: calc(var(--nav-offset) - 12px);
  }

  .breakdown-list { display: flex; flex-direction: column; gap: 10px; }

  .break-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px;
    border-radius: 16px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
  }

  .break-left { display: flex; align-items: center; gap: 10px; min-width: 0; }

  .break-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .break-name { font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.82); line-height: 1.5; }
  .break-val  { font-size: 13px; font-weight: 800; color: #fff; white-space: nowrap; flex-shrink: 0; }

  .summary-lines { display: flex; flex-direction: column; gap: 12px; }

  .sum-line {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .sum-line:last-child { padding-bottom: 0; border-bottom: 0; }

  .sum-k { font-size: 12px; color: rgba(255,255,255,0.46); line-height: 1.5; }

  .sum-v {
    text-align: right;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    line-height: 1.6;
    word-break: break-word;
    max-width: 60%;
  }

  .footer-note {
    text-align: center;
    padding-top: 28px;
    font-size: 10px;
    color: rgba(255,255,255,0.16);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.8;
  }

  /* ─── RESPONSIVE ──────────────────────────────── */
  @media (max-width: 1100px) {
    .hero-grid,
    .layout-grid { grid-template-columns: 1fr; }
    .side-stack { position: static; top: auto; }
    .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 768px) {
    :root { --nav-offset: 96px; }
    .page { padding: var(--nav-offset) 14px 40px; }
    .hero, .card { padding: 18px; border-radius: 18px; }
    .hero-title { font-size: 28px; }
    .hero-subtitle { font-size: 13px; line-height: 1.8; }
    .stats-grid { grid-template-columns: 1fr; }
    .mini-grid { grid-template-columns: 1fr; }
    .wi-top { flex-direction: column; }
    .wi-progress-box { width: 100%; min-width: 0; text-align: left; }
    .top-actions-left, .top-actions-right { width: 100%; }
    .top-actions-right { justify-content: flex-start; }
    .hero-meta { flex-direction: column; }
    .meta-pill { width: 100%; justify-content: flex-start; }
    .sum-v { max-width: 58%; }
  }

  @media (max-width: 520px) {
    :root { --nav-offset: 88px; }
    .page { padding: var(--nav-offset) 12px 34px; }
    .hero { padding: 16px; border-radius: 16px; }
    .card { padding: 16px; border-radius: 16px; }
    .top-actions { gap: 10px; }
    .ghost-btn, .chip-btn, .print-btn { width: 100%; }
    .hero-topline { gap: 8px; }
    .section-chip, .status-badge { width: 100%; justify-content: center; }
    .hero-title { font-size: 24px; }
    .eng-row { align-items: flex-start; }
    .eng-avatar { width: 48px; height: 48px; border-radius: 14px; font-size: 15px; }
    .eng-name { font-size: 17px; }
    .mini-grid { grid-template-columns: 1fr; }
    .stat-value { font-size: 28px; }
    .wi-name { font-size: 16px; }
    .wi-pct { font-size: 26px; }
    .break-item, .sum-line { flex-direction: column; align-items: flex-start; }
    .break-val, .sum-v { text-align: left; max-width: 100%; white-space: normal; }
    .mp-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .footer-note { font-size: 9px; }
  }

  @media (max-width: 380px) {
    .mp-grid { grid-template-columns: 1fr; }
    .wi-left { gap: 10px; }
    .wi-num { width: 34px; height: 34px; }
  }

  /* ═══════════════════════════════════════════════════════════
     PRINT STYLES
     ═══════════════════════════════════════════════════════════ */

