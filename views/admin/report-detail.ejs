    }

    .work-list { gap: 8px !important; }

    .work-item {
      background: #fff !important;
      border: 1px solid #e0e0e0 !important;
      border-radius: 10px !important;
      padding: 10px 14px !important;
      page-break-inside: avoid;
      break-inside: avoid;
      border-left: 4px solid #ccc !important;
    }

    .work-item[data-status="on-track"]        { border-left-color: #16a34a !important; }
    .work-item[data-status="in-progress"]     { border-left-color: #d97706 !important; }
    .work-item[data-status="needs-attention"] { border-left-color: #dc2626 !important; }

    .wi-top { display: grid !important; grid-template-columns: 1fr 80px !important; align-items: start !important; gap: 10px !important; margin-bottom: 8px !important; }
    .wi-left { display: flex !important; align-items: flex-start !important; gap: 8px !important; min-width: 0 !important; }
