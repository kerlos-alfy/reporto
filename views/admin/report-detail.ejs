<%
  // ── helpers ──────────────────────────────────────────────────
  function fmt(d) {
    if (!d) return '—';
    const dt = new Date(d);
    return dt.toLocaleDateString('en-GB', {
      day: '2-digit',
      month: 'short',
      year: 'numeric'
    });
  }

  function dur(mins) {
    if (!mins && mins !== 0) return null;
    const h = Math.floor(mins / 60);
    const m = mins % 60;
    if (h && m) return h + 'h ' + m + 'm';
    if (h) return h + 'h';
    return m + 'm';
  }

  function pColor(p) {
    return p >= 80 ? '#22c55e' : p >= 45 ? '#f59e0b' : '#ef4444';
  }

  function pSoft(p) {
    return p >= 80 ? 'rgba(34,197,94,0.14)' : p >= 45 ? 'rgba(245,158,11,0.14)' : 'rgba(239,68,68,0.14)';
  }

  function pBorder(p) {
    return p >= 80 ? 'rgba(34,197,94,0.28)' : p >= 45 ? 'rgba(245,158,11,0.28)' : 'rgba(239,68,68,0.28)';
  }

  function pLabel(p) {
    return p >= 80 ? 'On Track' : p >= 45 ? 'In Progress' : 'Needs Attention';
  }

  // print-safe solid colors
  function pColorPrint(p) {
    return p >= 80 ? '#16a34a' : p >= 45 ? '#d97706' : '#dc2626';
  }

  function initials(name) {
    return (name || '?')
      .split(' ')
      .map(w => w[0])
      .join('')
      .slice(0, 2)
      .toUpperCase();
  }

  function safePct(val) {
    const n = Number(val);
    if (isNaN(n)) return 0;
    if (n < 0) return 0;
    if (n > 100) return 100;
    return n;
  }

  const avgProgress = Math.round(report.averageProgress || 0);
  const allItems = report.items || [];
  const itemsCount = report.itemsCount || allItems.length || 0;

  // ── Compute real totalManpower from sources[] (new schema), fallback to stored value ──
  const reportTotalManpower = (function() {
    let total = 0;
    allItems.forEach(function(item) {
      if (item.sources && item.sources.length > 0) {
        item.sources.forEach(function(s) { total += (Number(s.totalManpower) || 0); });
      } else {
        total += (Number(item.totalManpower) || 0) + (Number(item.externalTotalManpower) || 0);
      }
    });
    return total || (Number(report.totalManpower) || 0);
  })();

  // Support both new sources[] schema and legacy laborSourceType field
  function itemHasSourceType(item, type) {
    if (item.sources && item.sources.length > 0) {
      return item.sources.some(s => s.type === type);
    }
    if (type === 'In-House') return !item.laborSourceType || item.laborSourceType === 'In-House';
    return item.laborSourceType === type;
  }
  const inHouse  = allItems.filter(i => itemHasSourceType(i, 'In-House')).length;
  const supplier = allItems.filter(i => itemHasSourceType(i, 'Supplier')).length;
  const subcon   = allItems.filter(i => itemHasSourceType(i, 'Subcontractor')).length;

  const reportStatus = pLabel(avgProgress);
  const reportStatusColor = pColor(avgProgress);
  const reportStatusBg = pSoft(avgProgress);
  const reportStatusBorder = pBorder(avgProgress);
  const reportStatusPrint = pColorPrint(avgProgress);
%>
<!DOCTYPE html>
<html lang="en" data-theme="<%= (typeof adminUser !== 'undefined' && adminUser && adminUser.theme) ? adminUser.theme : 'navy' %>">
<head>
  <!-- Theme: apply before render to prevent flash -->
  <script>
    (function(){var t=localStorage.getItem('ag_theme');if(t&&['navy','cyan','amber'].includes(t)){document.documentElement.setAttribute('data-theme',t);if(t==='light')document.documentElement.classList.remove('dark');else document.documentElement.classList.add('dark');}})();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
