<!DOCTYPE html>
<html lang="en" data-theme="<%= (typeof adminUser !== 'undefined' && adminUser && adminUser.theme) ? adminUser.theme : 'navy' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="/assets/images/logo.png">
  <title>Manpower Summary — Reporto</title>
  <script>(function(){var t=localStorage.getItem('ag_theme');if(t&&['navy','cyan','amber'].includes(t)){document.documentElement.setAttribute('data-theme',t);}})();</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: {
        colors: { brand: { 950:'var(--surface-950)',900:'var(--surface-900)',850:'var(--surface-850)',800:'var(--surface-800)',700:'var(--surface-700)' } },
        fontFamily: { sans:['DM Sans','system-ui','sans-serif'], mono:['JetBrains Mono','monospace'] }
      }}
    }
  </script>
  <link rel="stylesheet" href="/css/app.css">
  <script src="/js/theme.js"></script>
  <style>
    .ms-card { background:linear-gradient(145deg,rgba(255,255,255,.04) 0%,rgba(255,255,255,.02) 100%); border:1px solid var(--border-subtle); border-radius:20px; overflow:hidden; }
    .ms-card-header { background:linear-gradient(90deg,var(--accent-a08) 0%,transparent 100%); border-bottom:1px solid var(--border-subtle); padding:18px 24px; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; }
    .ms-pill { display:inline-flex; align-items:center; gap:6px; padding:5px 12px; border-radius:999px; font-size:12px; font-weight:600; font-family:var(--font-mono); border:1px solid; }
    .ms-pill-ih  { color:#34d399; border-color:rgba(52,211,153,.25);  background:rgba(52,211,153,.07); }
    .ms-pill-sup { color:#60a5fa; border-color:rgba(96,165,250,.25);  background:rgba(96,165,250,.07); }
    .ms-pill-sub { color:#f472b6; border-color:rgba(244,114,182,.25); background:rgba(244,114,182,.07); }
    .ms-pill-tot { color:var(--accent); border-color:var(--accent-a25); background:var(--accent-a08); }
    .ms-timeline { padding:0 24px 20px; }
    .ms-day-row { display:grid; grid-template-columns:110px 1fr; gap:0; border-bottom:1px solid var(--border-subtle); padding:14px 0; align-items:start; }
    .ms-day-row:last-child { border-bottom:none; }
    .ms-date { font-family:var(--font-mono); font-size:11px; color:var(--text-secondary); padding-right:16px; padding-top:2px; }
    .ms-day-content { display:flex; flex-direction:column; gap:8px; }
    .ms-manpower-row { display:flex; flex-wrap:wrap; gap:6px; align-items:center; }
    .ms-engineers { display:flex; flex-wrap:wrap; gap:4px; align-items:center; }
    .ms-eng-tag { display:inline-flex; align-items:center; gap:4px; font-size:11px; color:var(--text-secondary); background:rgba(255,255,255,.04); border:1px solid var(--border-subtle); border-radius:6px; padding:2px 8px; }
    .ms-bar-wrap { height:5px; border-radius:99px; background:rgba(255,255,255,.06); margin-top:6px; overflow:hidden; display:flex; gap:1px; }
    .ms-bar-seg { height:100%; border-radius:99px; transition:width .4s ease; }
    .ms-bar-ih  { background:#34d399; }
    .ms-bar-sup { background:#60a5fa; }
    .ms-bar-sub { background:#f472b6; }
    .ms-collapse { overflow:hidden; transition:max-height .35s cubic-bezier(.4,0,.2,1); }
    .ms-filter-input { background:var(--surface-800); border:1px solid var(--border-subtle); border-radius:10px; color:var(--text-primary); font-size:13px; padding:8px 12px; outline:none; transition:border-color .2s; }
    .ms-filter-input:focus { border-color:var(--accent-a25); }
    .ms-filter-input option { background:var(--surface-800); }
    .ms-filter-input:disabled { opacity:.4; cursor:not-allowed; }
    .ms-active-filters { display:flex; flex-wrap:wrap; gap:6px; margin-top:12px; padding-top:12px; border-top:1px solid var(--border-subtle); }
    .ms-chip { display:inline-flex; align-items:center; gap:5px; padding:3px 10px; border-radius:999px; font-size:10px; font-weight:700; letter-spacing:.04em; }
    .ms-chip-act { background:rgba(201,168,76,.1);  color:var(--accent); border:1px solid rgba(201,168,76,.2); }
    .ms-chip-lvl { background:rgba(167,139,250,.1); color:#c4b5fd;       border:1px solid rgba(167,139,250,.2); }
    .ms-chip-elm { background:rgba(96,165,250,.1);  color:#7AB8FC;        border:1px solid rgba(96,165,250,.2); }
    .ms-skeleton { background:linear-gradient(90deg,var(--surface-800) 25%,var(--surface-700) 50%,var(--surface-800) 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
    @keyframes shimmer { from{background-position:200% 0} to{background-position:-200% 0} }
    .ms-empty { text-align:center; padding:60px 24px; color:var(--text-muted); }
    .ms-empty svg { margin:0 auto 16px; opacity:.3; }
  </style>
</head>
<body class="bg-brand-950 text-gray-200 font-sans min-h-screen antialiased">
  <%- include('../partials/navbar') %>
  <main class="pt-20 sm:pt-[88px]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-1">
          <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:var(--accent-a08);border:1px solid var(--accent-a15);">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="color:var(--accent)"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div>
            <h1 class="text-xl sm:text-2xl font-bold text-white tracking-tight">Manpower Summary</h1>
            <p class="text-sm mt-0.5" style="color:var(--text-secondary)">Daily workforce breakdown per site — In-House, Supplier & Subcontractor</p>
          </div>
        </div>
      </div>

      <!-- Filters -->
      <div class="ms-card mb-6 p-4">
        <div class="flex flex-wrap gap-3 items-end">
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">From</label>
            <input type="date" id="filter-from" class="ms-filter-input">
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">To</label>
            <input type="date" id="filter-to" class="ms-filter-input">
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">Site</label>
            <select id="filter-project" class="ms-filter-input pr-8" onchange="onProjectChange(this.value)">
              <option value="">All Sites</option>
              <% filterOptions.projects.forEach(p => { %>
                <option value="<%= p.id %>"><%= p.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">Activity</label>
            <select id="filter-activity" class="ms-filter-input pr-8" disabled>
              <option value="">All Activities</option>
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">Level</label>
            <select id="filter-level" class="ms-filter-input pr-8" disabled>
              <option value="">All Levels</option>
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">Element</label>
            <select id="filter-element" class="ms-filter-input pr-8" disabled>
              <option value="">All Elements</option>
            </select>
          </div>
          <div class="flex gap-2 items-end">
            <button id="btn-apply" class="ag-btn-gold" style="height:38px;">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              Apply
            </button>
            <button id="btn-reset" class="ag-btn-ghost" style="height:38px;">Reset</button>
          </div>
        </div>
        <div id="active-filter-chips" class="ms-active-filters" style="display:none"></div>
      </div>

      <!-- Legend -->
      <div class="flex flex-wrap gap-4 mb-5 px-1">
        <span class="flex items-center gap-2 text-xs font-semibold" style="color:#34d399"><span class="w-2.5 h-2.5 rounded-full bg-emerald-400 flex-shrink-0"></span>In-House</span>
        <span class="flex items-center gap-2 text-xs font-semibold" style="color:#60a5fa"><span class="w-2.5 h-2.5 rounded-full bg-blue-400 flex-shrink-0"></span>Supplier</span>
        <span class="flex items-center gap-2 text-xs font-semibold" style="color:#f472b6"><span class="w-2.5 h-2.5 rounded-full bg-pink-400 flex-shrink-0"></span>Subcontractor</span>
      </div>

      <!-- Content -->
      <div id="ms-content">
        <div id="ms-skeleton" class="space-y-4">
          <% for(let i=0;i<3;i++) { %>
          <div class="ms-card">
            <div class="ms-card-header">
              <div class="ms-skeleton h-5 w-48 rounded"></div>
              <div class="flex gap-2"><div class="ms-skeleton h-6 w-20 rounded-full"></div><div class="ms-skeleton h-6 w-20 rounded-full"></div></div>
            </div>
            <div class="p-6 space-y-4"><% for(let j=0;j<2;j++) { %><div class="ms-skeleton h-10 w-full rounded-lg"></div><% } %></div>
          </div>
          <% } %>
        </div>
        <div id="ms-cards" class="space-y-5 hidden"></div>
        <div id="ms-empty" class="ms-card hidden">
          <div class="ms-empty">
            <svg class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-base font-semibold text-white/50 mt-2">No data found</p>
            <p class="text-sm text-white/30 mt-1">Try adjusting your filters</p>
          </div>
        </div>
      </div>

    </div>
  </main>

  <script>
  (function() {
    // ── Dynamic filter options ─────────────────────────────────────────────────
    window.onProjectChange = async function(projectId) {
      const actSel  = document.getElementById('filter-activity');
      const lvlSel  = document.getElementById('filter-level');
      const elmSel  = document.getElementById('filter-element');

      // Reset all three
      ['filter-activity','filter-level','filter-element'].forEach(id => {
        const el = document.getElementById(id);
        el.innerHTML = `<option value="">All ${id.split('-')[1].charAt(0).toUpperCase()+id.split('-')[1].slice(1)}s</option>`;
        el.disabled = !projectId;
      });

      if (!projectId) return;

      try {
        const resp = await fetch(`/api/admin/filter-options?project=${projectId}`);
        const data = await resp.json();
        if (!data.success) return;

        const fill = (sel, items, label) => {
          sel.innerHTML = `<option value="">All ${label}</option>` +
            items.map(v => `<option value="${v}">${v}</option>`).join('');
          sel.disabled = false;
        };

        fill(actSel, data.activities, 'Activities');
        fill(lvlSel, data.levels,     'Levels');
        fill(elmSel, data.elements,   'Elements');
      } catch(e) {
        console.error('Filter options error:', e);
      }
    };

    // ── Helpers ────────────────────────────────────────────────────────────────
    function fmt(n) { return (n||0).toLocaleString(); }
    function fmtDate(str) {
      const [y,m,d] = str.split('-');
      const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return `${d} ${months[parseInt(m)-1]} ${y}`;
    }
    function pillHTML(cls,label,val) {
      if (!val) return '';
      return `<span class="ms-pill ${cls}"><span>${label}</span><span>${fmt(val)}</span></span>`;
    }
    function barHTML(ih,sup,sub) {
      const total = ih+sup+sub; if (!total) return '';
      const pIH=Math.round(ih/total*100), pSup=Math.round(sup/total*100), pSub=100-pIH-pSup;
      return `<div class="ms-bar-wrap">
        ${ih  ?`<div class="ms-bar-seg ms-bar-ih"  style="width:${pIH}%"></div>`:''}
        ${sup ?`<div class="ms-bar-seg ms-bar-sup" style="width:${pSup}%"></div>`:''}
        ${sub ?`<div class="ms-bar-seg ms-bar-sub" style="width:${pSub}%"></div>`:''}
      </div>`;
    }
    function engTagsHTML(engineers) {
      if (!engineers||!engineers.length) return '';
      return `<div class="ms-engineers mt-1">
        <svg class="w-3 h-3 flex-shrink-0 opacity-40 mr-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        ${engineers.map(e=>`<span class="ms-eng-tag">${e}</span>`).join('')}
      </div>`;
    }

    function buildCard(site,idx) {
      const bodyId=`ms-body-${idx}`, isOpen=idx<3;
      const headerPills=`
        ${pillHTML('ms-pill-ih','In-House',site.totalInHouse)}
        ${pillHTML('ms-pill-sup','Supplier',site.totalSupplier)}
        ${pillHTML('ms-pill-sub','Sub',site.totalSubcontractor)}
        <span class="ms-pill ms-pill-tot">Total&nbsp;${fmt(site.grandTotal)}</span>`;
      const daysHTML=site.days.map(d=>`
        <div class="ms-day-row">
          <div class="ms-date">${fmtDate(d.date)}</div>
          <div class="ms-day-content">
            <div class="ms-manpower-row">
              ${pillHTML('ms-pill-ih','IH',d.inHouse)}
              ${pillHTML('ms-pill-sup','Sup',d.supplier)}
              ${pillHTML('ms-pill-sub','Sub',d.subcontractor)}
              ${d.total?`<span class="ms-pill ms-pill-tot">${fmt(d.total)}</span>`:''}
            </div>
            ${barHTML(d.inHouse,d.supplier,d.subcontractor)}
            ${engTagsHTML(d.engineers)}
          </div>
        </div>`).join('');
      const maxH=isOpen?`${site.days.length*100+100}px`:'0px';
      return `<div class="ms-card">
        <div class="ms-card-header" style="cursor:pointer" onclick="toggleCard('${bodyId}',this)">
          <div class="flex items-center gap-3 min-w-0">
            <div class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center" style="background:var(--accent-a08);border:1px solid var(--accent-a15);">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--accent)"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <span class="font-bold text-white text-base truncate">${site.siteName}</span>
            <span class="text-xs flex-shrink-0" style="color:var(--text-muted)">${site.days.length} day${site.days.length!==1?'s':''}</span>
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <div class="flex flex-wrap gap-2">${headerPills}</div>
            <svg class="ms-chevron w-4 h-4 flex-shrink-0 transition-transform duration-300 ${isOpen?'rotate-180':''}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--text-secondary)"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </div>
        </div>
        <div class="ms-collapse ms-timeline" id="${bodyId}" style="max-height:${maxH}">
          ${site.days.length?daysHTML:'<p class="py-6 text-center text-sm" style="color:var(--text-muted)">No daily data</p>'}
        </div>
      </div>`;
    }

    window.toggleCard = function(bodyId,header) {
      const body=document.getElementById(bodyId), chev=header.querySelector('.ms-chevron');
      const isOpen=body.style.maxHeight!=='0px';
      body.style.maxHeight=isOpen?'0px':(body.scrollHeight+40)+'px';
      chev.classList.toggle('rotate-180',!isOpen);
    };

    function updateChips() {
      const activity = document.getElementById('filter-activity').value;
      const level    = document.getElementById('filter-level').value;
      const element  = document.getElementById('filter-element').value;
      const wrap     = document.getElementById('active-filter-chips');
      let html='';
      if (activity) html+=`<span class="ms-chip ms-chip-act">Activity: ${activity}</span>`;
      if (level)    html+=`<span class="ms-chip ms-chip-lvl">Level: ${level}</span>`;
      if (element)  html+=`<span class="ms-chip ms-chip-elm">Element: ${element}</span>`;
      wrap.innerHTML=html; wrap.style.display=html?'flex':'none';
    }

    async function loadData() {
      const from     = document.getElementById('filter-from').value;
      const to       = document.getElementById('filter-to').value;
      const project  = document.getElementById('filter-project').value;
      const activity = document.getElementById('filter-activity').value;
      const level    = document.getElementById('filter-level').value;
      const element  = document.getElementById('filter-element').value;
      updateChips();
      document.getElementById('ms-skeleton').classList.remove('hidden');
      document.getElementById('ms-cards').classList.add('hidden');
      document.getElementById('ms-empty').classList.add('hidden');
      const params=new URLSearchParams();
      if(from)     params.set('fromDate',from);
      if(to)       params.set('toDate',to);
      if(project)  params.set('project',project);
      if(activity) params.set('activity',activity);
      if(level)    params.set('level',level);
      if(element)  params.set('element',element);
      try {
        const resp=await fetch(`/api/admin/manpower-summary?${params}`);
        const data=await resp.json();
        document.getElementById('ms-skeleton').classList.add('hidden');
        if(!data.success||!data.sites||!data.sites.length){ document.getElementById('ms-empty').classList.remove('hidden'); return; }
        const cardsEl=document.getElementById('ms-cards');
        cardsEl.innerHTML=data.sites.map((s,i)=>buildCard(s,i)).join('');
        cardsEl.classList.remove('hidden');
      } catch(err) {
        document.getElementById('ms-skeleton').classList.add('hidden');
        document.getElementById('ms-empty').classList.remove('hidden');
      }
    }

    // Default dates
    (function(){
      const today=new Date(), from=new Date(today);
      from.setDate(from.getDate()-29);
      const f=d=>d.toISOString().slice(0,10);
      document.getElementById('filter-to').value=f(today);
      document.getElementById('filter-from').value=f(from);
    })();

    document.getElementById('btn-apply').addEventListener('click',loadData);
    document.getElementById('btn-reset').addEventListener('click',()=>{
      const today=new Date(), from=new Date(today);
      from.setDate(from.getDate()-29);
      const f=d=>d.toISOString().slice(0,10);
      document.getElementById('filter-to').value=f(today);
      document.getElementById('filter-from').value=f(from);
      document.getElementById('filter-project').value='';
      ['filter-activity','filter-level','filter-element'].forEach(id=>{
        const el=document.getElementById(id);
        el.innerHTML=`<option value="">All ${id.split('-')[1].charAt(0).toUpperCase()+id.split('-')[1].slice(1)}s</option>`;
        el.disabled=true;
      });
      loadData();
    });

    loadData();
  })();
  </script>
</body>
</html>
