<!DOCTYPE html>
<html lang="en" data-theme="<%= (typeof adminUser !== 'undefined' && adminUser && adminUser.theme) ? adminUser.theme : 'navy' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="/assets/images/logo.png">
  <title>Manpower Breakdown — Reporto</title>
  <script>(function(){var t=localStorage.getItem('ag_theme');if(t&&['navy','cyan','amber'].includes(t)){document.documentElement.setAttribute('data-theme',t);}})();</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme:{ extend:{
        colors:{ brand:{ 950:'var(--surface-950)',900:'var(--surface-900)',850:'var(--surface-850)',800:'var(--surface-800)',700:'var(--surface-700)' } },
        fontFamily:{ sans:['DM Sans','system-ui','sans-serif'], mono:['JetBrains Mono','monospace'] }
      }}
    }
  </script>
  <link rel="stylesheet" href="/css/app.css">
  <script src="/js/theme.js"></script>
  <style>
    .mb-card { background:linear-gradient(145deg,rgba(255,255,255,.04) 0%,rgba(255,255,255,.02) 100%); border:1px solid var(--border-subtle); border-radius:20px; overflow:hidden; }
    .mb-card-header { background:linear-gradient(90deg,var(--accent-a08) 0%,transparent 100%); border-bottom:1px solid var(--border-subtle); padding:16px 22px; display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; cursor:pointer; }
    .mb-source { border-bottom:1px solid var(--border-subtle); padding:14px 22px; }
    .mb-source:last-child { border-bottom:none; }
    .mb-source-header { display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap:wrap; margin-bottom:10px; }
    .mb-trades { display:flex; flex-wrap:wrap; gap:6px; }
    .mb-trade-chip { display:inline-flex; align-items:center; gap:6px; padding:5px 11px; border-radius:8px; font-size:12px; font-weight:500; background:rgba(255,255,255,.04); border:1px solid var(--border-subtle); color:var(--text-secondary); font-family:var(--font-mono); }
    .mb-trade-chip .mb-count { font-weight:700; color:var(--text-primary); }
    .mb-pill { display:inline-flex; align-items:center; gap:6px; padding:4px 11px; border-radius:999px; font-size:12px; font-weight:600; font-family:var(--font-mono); border:1px solid; }
    .mb-pill-ih  { color:#34d399; border-color:rgba(52,211,153,.25);  background:rgba(52,211,153,.07); }
    .mb-pill-sup { color:#60a5fa; border-color:rgba(96,165,250,.25);  background:rgba(96,165,250,.07); }
    .mb-pill-sub { color:#f472b6; border-color:rgba(244,114,182,.25); background:rgba(244,114,182,.07); }
    .mb-pill-tot { color:var(--accent); border-color:var(--accent-a25); background:var(--accent-a08); }
    .mb-src-badge { display:inline-flex; align-items:center; padding:3px 10px; border-radius:6px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; }
    .mb-src-ih  { color:#34d399; background:rgba(52,211,153,.10);  border:1px solid rgba(52,211,153,.20); }
    .mb-src-sup { color:#60a5fa; background:rgba(96,165,250,.10);  border:1px solid rgba(96,165,250,.20); }
    .mb-src-sub { color:#f472b6; background:rgba(244,114,182,.10); border:1px solid rgba(244,114,182,.20); }
    .mb-collapse { overflow:hidden; transition:max-height .35s cubic-bezier(.4,0,.2,1); }
    .mb-filter-input { background:var(--surface-800); border:1px solid var(--border-subtle); border-radius:10px; color:var(--text-primary); font-size:13px; padding:8px 12px; outline:none; transition:border-color .2s; }
    .mb-filter-input:focus { border-color:var(--accent-a25); }
    .mb-filter-input option { background:var(--surface-800); }
    .mb-filter-input:disabled { opacity:.4; cursor:not-allowed; }
    .mb-toggle-group { display:flex; gap:4px; }
    .mb-toggle-btn { padding:6px 14px; border-radius:8px; font-size:12px; font-weight:600; border:1px solid var(--border-subtle); background:transparent; color:var(--text-secondary); cursor:pointer; transition:all .18s; }
    .mb-toggle-btn:hover { border-color:var(--accent-a25); color:var(--text-primary); }
    .mb-toggle-btn.active { background:var(--accent-a08); border-color:var(--accent-a25); color:var(--accent); }
    .mb-active-filters { display:flex; flex-wrap:wrap; gap:6px; margin-top:12px; padding-top:12px; border-top:1px solid var(--border-subtle); }
    .mb-chip { display:inline-flex; align-items:center; gap:5px; padding:3px 10px; border-radius:999px; font-size:10px; font-weight:700; letter-spacing:.04em; }
    .mb-chip-act { background:rgba(201,168,76,.1);  color:var(--accent); border:1px solid rgba(201,168,76,.2); }
    .mb-chip-lvl { background:rgba(167,139,250,.1); color:#c4b5fd;       border:1px solid rgba(167,139,250,.2); }
    .mb-chip-elm { background:rgba(96,165,250,.1);  color:#7AB8FC;        border:1px solid rgba(96,165,250,.2); }
    .mb-skeleton { background:linear-gradient(90deg,var(--surface-800) 25%,var(--surface-700) 50%,var(--surface-800) 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:8px; }
    @keyframes shimmer { from{background-position:200% 0} to{background-position:-200% 0} }
    .mb-empty { text-align:center; padding:60px 24px; color:var(--text-muted); }
  </style>
</head>
<body class="bg-brand-950 text-gray-200 font-sans min-h-screen antialiased">
  <%- include('../partials/navbar') %>
  <main class="pt-20 sm:pt-[88px]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center justify-between gap-3 mb-1 flex-wrap">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:var(--accent-a08);border:1px solid var(--accent-a15);">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" style="color:var(--accent)"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
            </div>
            <div>
              <h1 class="text-xl sm:text-2xl font-bold text-white tracking-tight">Manpower Breakdown</h1>
              <p class="text-sm mt-0.5" style="color:var(--text-secondary)">Trade-level breakdown per project — In-House, Suppliers & Subcontractors</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <button id="btn-export-excel" onclick="handleExport('excel')"
              class="flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold transition-all duration-200 disabled:opacity-40"
              style="background:rgba(52,211,153,.10);border:1px solid rgba(52,211,153,.25);color:#34d399"
              onmouseover="this.style.background='rgba(52,211,153,.18)'" onmouseout="this.style.background='rgba(52,211,153,.10)'">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
              <span class="hidden sm:inline">Excel</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Filters -->
      <div class="mb-card mb-6 p-4">
        <div class="flex flex-wrap gap-3 items-end">
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">From</label>
            <input type="date" id="filter-from" class="mb-filter-input">
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">To</label>
            <input type="date" id="filter-to" class="mb-filter-input">
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">Project</label>
            <select id="filter-project" class="mb-filter-input pr-8" onchange="onProjectChange(this.value)">
              <option value="">All Projects</option>
              <% filterOptions.projects.forEach(p => { %>
                <option value="<%= p.id %>"><%= p.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">Activity</label>
            <select id="filter-activity" class="mb-filter-input pr-8" disabled>
              <option value="">All Activities</option>
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">Level</label>
            <select id="filter-level" class="mb-filter-input pr-8" disabled>
              <option value="">All Levels</option>
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">Element</label>
            <select id="filter-element" class="mb-filter-input pr-8" disabled>
              <option value="">All Elements</option>
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold uppercase tracking-wide" style="color:var(--text-muted)">Source</label>
            <div class="mb-toggle-group" id="source-toggle">
              <button class="mb-toggle-btn active" data-val="all">All</button>
              <button class="mb-toggle-btn" data-val="In-House">In-House</button>
              <button class="mb-toggle-btn" data-val="External">External</button>
            </div>
          </div>
          <div class="flex gap-2 items-end">
            <button id="btn-apply" class="ag-btn-gold" style="height:38px;">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              Apply
            </button>
            <button id="btn-reset" class="ag-btn-ghost" style="height:38px;">Reset</button>
          </div>
        </div>
        <div id="active-filter-chips" class="mb-active-filters" style="display:none"></div>
      </div>

      <!-- Legend -->
      <div class="flex flex-wrap gap-4 mb-5 px-1">
        <span class="flex items-center gap-2 text-xs font-semibold" style="color:#34d399"><span class="w-2.5 h-2.5 rounded-full bg-emerald-400 flex-shrink-0"></span>In-House</span>
        <span class="flex items-center gap-2 text-xs font-semibold" style="color:#60a5fa"><span class="w-2.5 h-2.5 rounded-full bg-blue-400 flex-shrink-0"></span>Supplier</span>
        <span class="flex items-center gap-2 text-xs font-semibold" style="color:#f472b6"><span class="w-2.5 h-2.5 rounded-full bg-pink-400 flex-shrink-0"></span>Subcontractor</span>
      </div>

      <!-- Content -->
      <div id="mb-content">
        <div id="mb-skeleton" class="space-y-4">
          <% for(let i=0;i<3;i++) { %>
          <div class="mb-card">
            <div class="mb-card-header"><div class="mb-skeleton h-5 w-48 rounded"></div><div class="flex gap-2"><div class="mb-skeleton h-6 w-20 rounded-full"></div><div class="mb-skeleton h-6 w-20 rounded-full"></div></div></div>
            <div class="p-5 space-y-3"><% for(let j=0;j<2;j++) { %><div class="mb-skeleton h-16 w-full rounded-lg"></div><% } %></div>
          </div>
          <% } %>
        </div>
        <div id="mb-cards" class="space-y-5 hidden"></div>
        <div id="mb-empty" class="mb-card hidden">
          <div class="mb-empty">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-base font-semibold text-white/50">No data found</p>
            <p class="text-sm text-white/30 mt-1">Try adjusting your filters</p>
          </div>
        </div>
      </div>

    </div>
  </main>

  <script>
  (function() {
    let activeSource = 'all';

    document.querySelectorAll('.mb-toggle-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mb-toggle-btn').forEach(b=>b.classList.remove('active'));
        btn.classList.add('active');
        activeSource = btn.dataset.val;
      });
    });

    // ── Dynamic filter options ─────────────────────────────────────────────────
    window.onProjectChange = async function(projectId) {
      const ids = ['filter-activity','filter-level','filter-element'];
      const labels = ['Activities','Levels','Elements'];
      ids.forEach((id,i) => {
        const el = document.getElementById(id);
        el.innerHTML = `<option value="">All ${labels[i]}</option>`;
        el.disabled = !projectId;
      });
      if (!projectId) return;
      try {
        const resp = await fetch(`/api/admin/filter-options?project=${projectId}`);
        const data = await resp.json();
        if (!data.success) return;
        const fill = (id, items, label) => {
          const el = document.getElementById(id);
          el.innerHTML = `<option value="">All ${label}</option>` + items.map(v=>`<option value="${v}">${v}</option>`).join('');
          el.disabled = false;
        };
        fill('filter-activity', data.activities, 'Activities');
        fill('filter-level',    data.levels,     'Levels');
        fill('filter-element',  data.elements,   'Elements');
      } catch(e) { console.error('Filter options error:',e); }
    };

    // ── Helpers ────────────────────────────────────────────────────────────────
    function fmt(n) { return (n||0).toLocaleString(); }
    function escHtml(str) { return (str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    function srcBadge(type, companyName) {
      if (type==='In-House') return `<span class="mb-src-badge mb-src-ih">In-House</span>`;
      if (type==='Supplier') return `<span class="mb-src-badge mb-src-sup">Supplier</span><span class="text-sm font-semibold ml-1" style="color:var(--text-primary)">${escHtml(companyName)}</span>`;
      return `<span class="mb-src-badge mb-src-sub">Subcontractor</span><span class="text-sm font-semibold ml-1" style="color:var(--text-primary)">${escHtml(companyName)}</span>`;
    }
    function srcPillClass(type) {
      if (type==='In-House') return 'mb-pill-ih';
      if (type==='Supplier') return 'mb-pill-sup';
      return 'mb-pill-sub';
    }

    function buildCard(project, idx) {
      const bodyId=`mb-body-${idx}`, isOpen=idx<4;
      let ihTotal=0, supTotal=0, subTotal=0;
      project.sources.forEach(s => {
        if(s.type==='In-House') ihTotal+=s.total;
        else if(s.type==='Supplier') supTotal+=s.total;
        else subTotal+=s.total;
      });
      const headerPills=`
        ${ihTotal  ?`<span class="mb-pill mb-pill-ih">IH&nbsp;${fmt(ihTotal)}</span>`:''}
        ${supTotal ?`<span class="mb-pill mb-pill-sup">Sup&nbsp;${fmt(supTotal)}</span>`:''}
        ${subTotal ?`<span class="mb-pill mb-pill-sub">Sub&nbsp;${fmt(subTotal)}</span>`:''}
        <span class="mb-pill mb-pill-tot">Total&nbsp;${fmt(project.grandTotal)}</span>`;
      const sourcesHTML=project.sources.map(src=>{
        const tradesHTML=src.tradesArr.map(t=>`<div class="mb-trade-chip"><span>${escHtml(t.label)}</span><span class="mb-count">${fmt(t.count)}</span></div>`).join('');
        return `<div class="mb-source">
          <div class="mb-source-header">
            <div class="flex items-center gap-2 flex-wrap">${srcBadge(src.type,src.companyName)}</div>
            <span class="mb-pill ${srcPillClass(src.type)}">${fmt(src.total)} workers</span>
          </div>
          <div class="mb-trades">${tradesHTML||'<span class="text-xs" style="color:var(--text-muted)">No trade details</span>'}</div>
        </div>`;
      }).join('');
      const maxH=isOpen?`${project.sources.length*160+60}px`:'0px';
      return `<div class="mb-card">
        <div class="mb-card-header" onclick="toggleMB('${bodyId}',this)">
          <div class="flex items-center gap-3 min-w-0">
            <div class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center" style="background:var(--accent-a08);border:1px solid var(--accent-a15);">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--accent)"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <span class="font-bold text-white text-base truncate">${escHtml(project.siteName)}</span>
            <span class="text-xs flex-shrink-0" style="color:var(--text-muted)">${project.sources.length} source${project.sources.length!==1?'s':''}</span>
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <div class="flex flex-wrap gap-2">${headerPills}</div>
            <svg class="mb-chevron w-4 h-4 flex-shrink-0 transition-transform duration-300 ${isOpen?'rotate-180':''}" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--text-secondary)"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </div>
        </div>
        <div class="mb-collapse" id="${bodyId}" style="max-height:${maxH}">
          ${sourcesHTML||'<p class="py-6 text-center text-sm" style="color:var(--text-muted)">No sources found</p>'}
        </div>
      </div>`;
    }

    window.toggleMB = function(bodyId,header) {
      const body=document.getElementById(bodyId), chev=header.querySelector('.mb-chevron');
      const isOpen=body.style.maxHeight!=='0px';
      body.style.maxHeight=isOpen?'0px':(body.scrollHeight+40)+'px';
      chev.classList.toggle('rotate-180',!isOpen);
    };

    function updateChips() {
      const activity=document.getElementById('filter-activity').value;
      const level=document.getElementById('filter-level').value;
      const element=document.getElementById('filter-element').value;
      const wrap=document.getElementById('active-filter-chips');
      let html='';
      if(activity) html+=`<span class="mb-chip mb-chip-act">Activity: ${escHtml(activity)}</span>`;
      if(level)    html+=`<span class="mb-chip mb-chip-lvl">Level: ${escHtml(level)}</span>`;
      if(element)  html+=`<span class="mb-chip mb-chip-elm">Element: ${escHtml(element)}</span>`;
      wrap.innerHTML=html; wrap.style.display=html?'flex':'none';
    }

    async function loadData() {
      const from    =document.getElementById('filter-from').value;
      const to      =document.getElementById('filter-to').value;
      const project =document.getElementById('filter-project').value;
      const activity=document.getElementById('filter-activity').value;
      const level   =document.getElementById('filter-level').value;
      const element =document.getElementById('filter-element').value;
      updateChips();
      document.getElementById('mb-skeleton').classList.remove('hidden');
      document.getElementById('mb-cards').classList.add('hidden');
      document.getElementById('mb-empty').classList.add('hidden');
      const params=new URLSearchParams();
      if(from)     params.set('fromDate',from);
      if(to)       params.set('toDate',to);
      if(project)  params.set('project',project);
      if(activity) params.set('activity',activity);
      if(level)    params.set('level',level);
      if(element)  params.set('element',element);
      params.set('sourceType',activeSource);
      try {
        const resp=await fetch(`/api/admin/manpower-breakdown?${params}`);
        const data=await resp.json();
        document.getElementById('mb-skeleton').classList.add('hidden');
        if(!data.success||!data.projects||!data.projects.length){ document.getElementById('mb-empty').classList.remove('hidden'); return; }
        const cardsEl=document.getElementById('mb-cards');
        cardsEl.innerHTML=data.projects.map((p,i)=>buildCard(p,i)).join('');
        cardsEl.classList.remove('hidden');
      } catch(err) {
        document.getElementById('mb-skeleton').classList.add('hidden');
        document.getElementById('mb-empty').classList.remove('hidden');
      }
    }

    (function(){
      const today=new Date(), from=new Date(today);
      from.setDate(from.getDate()-29);
      const f=d=>d.toISOString().slice(0,10);
      document.getElementById('filter-to').value=f(today);
      document.getElementById('filter-from').value=f(from);
    })();

    document.getElementById('btn-apply').addEventListener('click',loadData);
    document.getElementById('btn-reset').addEventListener('click',()=>{
      const today=new Date(), from=new Date(today);
      from.setDate(from.getDate()-29);
      const f=d=>d.toISOString().slice(0,10);
      document.getElementById('filter-to').value=f(today);
      document.getElementById('filter-from').value=f(from);
      document.getElementById('filter-project').value='';
      ['filter-activity','filter-level','filter-element'].forEach((id,i)=>{
        const el=document.getElementById(id);
        const labels=['Activities','Levels','Elements'];
        el.innerHTML=`<option value="">All ${labels[i]}</option>`;
        el.disabled=true;
      });
      document.querySelectorAll('.mb-toggle-btn').forEach(b=>b.classList.remove('active'));
      document.querySelector('.mb-toggle-btn[data-val="all"]').classList.add('active');
      activeSource='all';
      loadData();
    });

    window.handleExport = function(format) {
      const from    =document.getElementById('filter-from').value;
      const to      =document.getElementById('filter-to').value;
      const project =document.getElementById('filter-project').value;
      const activity=document.getElementById('filter-activity').value;
      const level   =document.getElementById('filter-level').value;
      const element =document.getElementById('filter-element').value;
      const btn=document.getElementById('btn-export-excel');
      const params=new URLSearchParams();
      if(from)     params.set('fromDate',from);
      if(to)       params.set('toDate',to);
      if(project)  params.set('project',project);
      if(activity) params.set('activity',activity);
      if(level)    params.set('level',level);
      if(element)  params.set('element',element);
      params.set('sourceType',activeSource);
      const origHTML=btn.innerHTML;
      btn.disabled=true;
      btn.innerHTML=`<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg><span class="hidden sm:inline">Exporting…</span>`;
      const link=document.createElement('a');
      link.href=`/api/admin/manpower-breakdown/export/${format}?${params}`;
      link.style.display='none';
      document.body.appendChild(link); link.click(); document.body.removeChild(link);
      setTimeout(()=>{ btn.disabled=false; btn.innerHTML=origHTML; },3500);
    };

    loadData();
  })();
  </script>
</body>
</html>
