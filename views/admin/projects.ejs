<!DOCTYPE html>
<html lang="en" data-theme="<%= (typeof adminUser !== 'undefined' && adminUser && adminUser.theme) ? adminUser.theme : 'navy' %>">
<head>
  <script>
    (function(){var t=localStorage.getItem('ag_theme');if(t&&['navy','cyan','amber'].includes(t)){document.documentElement.setAttribute('data-theme',t);if(t==='light')document.documentElement.classList.remove('dark');else document.documentElement.classList.add('dark');}})();
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="/assets/images/logo.png">
  <title>Projects — Reporto</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    :root {
      --gold:        #C9A84C;
      --gold-light:  #E2C97E;
      --gold-dim:    rgba(201,168,76,.18);
      --gold-glow:   rgba(201,168,76,.07);
      --navy-deep:   #030508;
      --navy-card:   rgba(10,15,30,.9);
      --border:      rgba(255,255,255,.06);
      --text:        #E2E8F0;
      --text-muted:  #5A6785;
      --text-dim:    #3A4560;
      --radius:      14px;
      --green:  #2DD4A0;
      --red:    #F56B6B;
      --blue:   #5BA3FA;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--navy-deep);
      color: var(--text);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Background ── */
    .bg-canvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
    .bg-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(201,168,76,.018) 1px, transparent 1px),
        linear-gradient(90deg, rgba(201,168,76,.018) 1px, transparent 1px);
      background-size: 48px 48px;
    }
    .bg-orb-1 {
      position: absolute; width: 700px; height: 700px;
      top: -200px; left: 50%; transform: translateX(-50%);
      background: radial-gradient(circle, rgba(201,168,76,.06) 0%, transparent 70%);
      border-radius: 50%;
    }
    .bg-orb-2 {
      position: absolute; width: 500px; height: 500px;
      bottom: 5%; right: -150px;
      background: radial-gradient(circle, rgba(91,163,250,.035) 0%, transparent 70%);
      border-radius: 50%;
    }

    /* ── Layout ── */
    .page { position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: 108px 28px 100px; }

    /* ── Breadcrumb ── */
    .breadcrumb-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 32px; flex-wrap: wrap; }
    .back-link {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11px; font-weight: 600; letter-spacing: .07em; text-transform: uppercase;
      text-decoration: none; color: var(--text-muted);
      padding: 7px 14px; border-radius: 100px;
      border: 1px solid var(--border); background: rgba(255,255,255,.025);
      transition: all .2s;
    }
    .back-link:hover { color: var(--gold); border-color: var(--gold-dim); background: var(--gold-glow); }
    .breadcrumb-sep { color: var(--text-dim); font-size: 10px; }
    .breadcrumb-cur { font-size: 11px; font-weight: 600; color: var(--text-muted); letter-spacing: .06em; text-transform: uppercase; }

    /* ── Page Hero ── */
    .page-hero { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 36px; flex-wrap: wrap; }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 12px; border-radius: 100px;
      background: var(--gold-dim); border: 1px solid rgba(201,168,76,.25);
      font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--gold);
      letter-spacing: .1em; text-transform: uppercase; margin-bottom: 10px;
    }
    .hero-eyebrow::before {
      content: ''; width: 5px; height: 5px; border-radius: 50%;
      background: var(--gold); animation: dot-pulse 2s infinite;
    }
    @keyframes dot-pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(1.4)} }
    .hero-title { font-size: clamp(24px,3vw,38px); font-weight: 800; color: #fff; line-height: 1.1; letter-spacing: -.02em; }
    .hero-sub { font-size: 13px; color: var(--text-muted); margin-top: 6px; }

    /* ── Toolbar ── */
    .toolbar { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
    .search-wrap { position: relative; flex: 1; max-width: 420px; }
    .search-icon { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: var(--text-dim); pointer-events: none; }
    .search-input {
      width: 100%;
      background: var(--navy-card);
      border: 1px solid var(--border);
      border-radius: 10px; padding: 10px 14px 10px 38px;
      color: var(--text); font-size: 13px; outline: none;
      font-family: 'DM Sans', sans-serif; transition: border-color .2s, background .2s;
    }
    .search-input::placeholder { color: var(--text-dim); }
    .search-input:focus { border-color: rgba(201,168,76,.35); background: rgba(201,168,76,.03); }

    .count-badge {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; color: var(--text-muted);
      background: rgba(255,255,255,.03);
      border: 1px solid var(--border);
      padding: 4px 12px; border-radius: 100px;
      white-space: nowrap;
    }

    /* ── Grid ── */
    .proj-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 14px;
    }

    /* ── Project Card ── */
    .proj-card {
      background: var(--navy-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 18px 14px;
      backdrop-filter: blur(20px);
      text-decoration: none; display: flex; flex-direction: column; gap: 8px;
      position: relative; overflow: hidden;
      transition: border-color .22s, transform .22s, box-shadow .22s;
    }
    /* Top shimmer line */
    .proj-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(201,168,76,.25), transparent);
      opacity: 0; transition: opacity .22s;
    }
    /* Bottom accent bar */
    .proj-card::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, var(--gold), var(--gold-light), transparent);
      transform: scaleX(0); transform-origin: left;
      transition: transform .3s ease;
    }
    .proj-card:hover {
      border-color: rgba(201,168,76,.22);
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(0,0,0,.4), 0 0 0 1px rgba(201,168,76,.06);
    }
    .proj-card:hover::before { opacity: 1; }
    .proj-card:hover::after  { transform: scaleX(1); }
    .proj-card.inactive { opacity: .5; }
    .proj-card:hover.inactive { opacity: .65; }

    /* Card inner glow on hover */
    .proj-card-glow {
      position: absolute; inset: 0; border-radius: var(--radius);
      background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(201,168,76,.05) 0%, transparent 70%);
      opacity: 0; transition: opacity .3s; pointer-events: none;
    }
    .proj-card:hover .proj-card-glow { opacity: 1; }

    /* Card top row */
    .proj-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
    .proj-code {
      display: inline-flex; align-items: center;
      padding: 3px 10px; border-radius: 100px;
      background: var(--gold-dim); border: 1px solid rgba(201,168,76,.22);
      font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 600;
      color: var(--gold); letter-spacing: .08em; text-transform: uppercase;
    }
    .proj-status-active {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 3px 10px; border-radius: 100px;
      background: rgba(45,212,160,.08); border: 1px solid rgba(45,212,160,.2);
      font-size: 9px; font-weight: 700; color: var(--green);
      letter-spacing: .06em; text-transform: uppercase;
    }
    .proj-status-active::before {
      content: ''; width: 5px; height: 5px; border-radius: 50%;
      background: var(--green); animation: dot-pulse 2.5s infinite;
    }
    .proj-status-inactive {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 3px 10px; border-radius: 100px;
      background: rgba(245,107,107,.08); border: 1px solid rgba(245,107,107,.2);
      font-size: 9px; font-weight: 700; color: var(--red);
      letter-spacing: .06em; text-transform: uppercase;
    }

    /* Card name */
    .proj-name {
      font-size: 15px; font-weight: 700; color: #fff; line-height: 1.3;
    }
    .proj-location {
      font-size: 11px; color: var(--text-muted);
      display: flex; align-items: center; gap: 5px;
    }
    .proj-location svg { flex-shrink: 0; opacity: .6; }

    /* Stats row */
    .proj-stats {
      display: flex; gap: 0;
      padding-top: 12px; margin-top: 4px;
      border-top: 1px solid rgba(255,255,255,.05);
    }
    .proj-stat {
      flex: 1; display: flex; flex-direction: column; gap: 3px;
      padding: 0 10px;
    }
    .proj-stat:first-child { padding-left: 0; }
    .proj-stat:last-child  { padding-right: 0; }
    .proj-stat + .proj-stat { border-left: 1px solid rgba(255,255,255,.05); }
    .proj-stat-val {
      font-family: 'JetBrains Mono', monospace;
      font-size: 15px; font-weight: 600; color: #fff; line-height: 1;
    }
    .proj-stat-lbl {
      font-size: 9px; color: var(--text-muted);
      text-transform: uppercase; letter-spacing: .08em; font-weight: 600;
    }

    /* Arrow CTA — inline, not absolute */
    .proj-cta {
      display: flex; align-items: center; gap: 5px;
      font-size: 10px; font-weight: 700; letter-spacing: .07em;
      color: rgba(201,168,76,.3); text-transform: uppercase;
      transition: color .2s, transform .2s;
      padding-top: 10px; align-self: flex-end;
    }
    .proj-card:hover .proj-cta { color: var(--gold); transform: translateX(2px); }

    /* ── Empty state ── */
    .empty-state {
      grid-column: 1 / -1;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 80px 20px; text-align: center;
      background: var(--navy-card); border: 1px dashed rgba(255,255,255,.08);
      border-radius: var(--radius);
    }
    .empty-state svg { color: var(--text-dim); margin-bottom: 14px; }
    .empty-state p { font-size: 13px; color: var(--text-muted); }
    .empty-state a { color: var(--gold); text-decoration: none; }
    .empty-state a:hover { text-decoration: underline; }

    /* ── No-results ── */
    .no-results {
      grid-column: 1 / -1; text-align: center;
      padding: 48px; font-size: 13px; color: var(--text-dim);
      display: none;
    }

    @media (max-width: 640px) {
      .page { padding: 96px 16px 80px; }
      .proj-grid { grid-template-columns: 1fr; }
    }
  </style>
  <script src="/js/theme.js"></script>
</head>
<body>

<div class="bg-canvas">
  <div class="bg-grid"></div>
  <div class="bg-orb-1"></div>
  <div class="bg-orb-2"></div>
</div>

<%- include('../partials/navbar') %>

<div class="page">

  <!-- Breadcrumb -->
  <div class="breadcrumb-bar">
    <a href="/admin/dashboard" class="back-link">
      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Dashboard
    </a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-cur">Projects</span>
  </div>

  <!-- Hero -->
  <div class="page-hero">
    <div>
      <div class="hero-eyebrow">
        <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Agile Prime
      </div>
      <h1 class="hero-title">Projects</h1>
      <p class="hero-sub">Select a project to view its daily timeline & activity log</p>
    </div>
  </div>

  <!-- Toolbar -->
  <div class="toolbar">
    <div class="search-wrap">
      <svg class="search-icon" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" id="projSearch" class="search-input" placeholder="Search by name, code or location…">
    </div>
    <span class="count-badge" id="projCount">
      <%= projects.filter(p=>p.isActive).length %> active · <%= projects.length %> total
    </span>
  </div>

  <!-- Grid -->
  <div class="proj-grid" id="projGrid">

    <% projects.forEach(p => { %>
    <a href="/admin/projects/<%= p._id %>/timeline"
       class="proj-card <%= p.isActive ? '' : 'inactive' %>"
       data-search="<%= (p.name+' '+(p.code||'')+' '+(p.location||'')).toLowerCase() %>">

      <div class="proj-card-glow"></div>

      <!-- Top row: code + status -->
      <div class="proj-card-top">
        <% if (p.code) { %>
          <span class="proj-code"><%= p.code %></span>
        <% } else { %>
          <span></span>
        <% } %>
        <% if (p.isActive) { %>
          <span class="proj-status-active">Active</span>
        <% } else { %>
          <span class="proj-status-inactive">Inactive</span>
        <% } %>
      </div>

      <!-- Name -->
      <div class="proj-name"><%= p.name %></div>

      <!-- Location -->
      <div class="proj-location">
        <% if (p.location) { %>
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <%= p.location %>
        <% } else { %>
          <span style="color:var(--text-dim);font-style:italic;font-size:11px">No location set</span>
        <% } %>
      </div>

      <!-- Stats -->
      <div class="proj-stats">
        <div class="proj-stat">
          <div class="proj-stat-val"><%= p.totalReports %></div>
          <div class="proj-stat-lbl">Reports</div>
        </div>
        <div class="proj-stat">
          <div class="proj-stat-val"><%= p.levelsCount %></div>
          <div class="proj-stat-lbl">Levels</div>
        </div>
        <div class="proj-stat">
          <% if (p.lastDate) { %>
            <div class="proj-stat-val" style="font-size:11px;letter-spacing:0"><%= p.lastDate %></div>
            <div class="proj-stat-lbl">Last Report</div>
          <% } else { %>
            <div class="proj-stat-val" style="font-size:11px;color:var(--text-dim)">—</div>
            <div class="proj-stat-lbl">No Reports</div>
          <% } %>
        </div>
      </div>

      <!-- CTA arrow -->
      <div class="proj-cta">
        <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Timeline
        <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </div>

    </a>
    <% }) %>

    <% if (projects.length === 0) { %>
    <div class="empty-state">
      <svg width="44" height="44" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
      <p>No projects yet. Add from <a href="/admin/master-data">Master Data</a>.</p>
    </div>
    <% } %>

    <div class="no-results" id="noResults">No projects match your search.</div>
  </div>

</div>

<script>
  const searchEl  = document.getElementById('projSearch');
  const countEl   = document.getElementById('projCount');
  const noResults = document.getElementById('noResults');
  const cards     = document.querySelectorAll('.proj-card');
  const total     = cards.length;
  const active    = <%= projects.filter(p=>p.isActive).length %>;

  searchEl?.addEventListener('input', function () {
    const q = this.value.toLowerCase().trim();
    let vis = 0;
    cards.forEach(c => {
      const show = !q || c.dataset.search.includes(q);
      c.style.display = show ? '' : 'none';
      if (show) vis++;
    });
    noResults.style.display = (vis === 0 && q) ? 'block' : 'none';
    if (countEl) {
      countEl.textContent = q
        ? `${vis} result${vis !== 1 ? 's' : ''}`
        : `${active} active · ${total} total`;
    }
  });
</script>

</body>
</html>
