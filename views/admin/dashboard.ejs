<body class="min-h-screen">
  <%- include('../partials/navbar') %>

  <main class="pt-20 pb-8 px-4 sm:px-6 lg:px-8">
  <!-- MISSING REPORT ALERT BANNER -->

  


    <div class="max-w-[1360px] mx-auto">
<div id="alertBanner" class="hidden mb-5">
    <div style="
      background: linear-gradient(135deg, rgba(245,158,11,0.10) 0%, rgba(245,158,11,0.05) 100%);
      border: 1px solid rgba(245,158,11,0.28);
      border-radius: 20px;
      padding: 16px 18px;
      position:relative; overflow:hidden;
    ">
      <!-- glow strip -->
      <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,rgba(245,158,11,0.6),transparent);border-radius:20px 20px 0 0;"></div>

      <div class="flex items-start gap-3">
        <!-- icon -->
        <div class="alert-icon shrink-0" style="
          width:42px;height:42px;border-radius:13px;
          background:rgba(245,158,11,0.15);
          border:1px solid rgba(245,158,11,0.25);
          display:flex;align-items:center;justify-content:center;
        ">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </div>

        <!-- content -->
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-0.5">
            <p style="color:#fbbf24;font-size:14px;font-weight:800;letter-spacing:-0.01em;">Missing Reports <span id="alertDateBadge" style="font-size:12px;color:rgba(251,191,36,0.75);font-weight:600;margin-left:4px;"></span></p>
            <span id="alertCountBadge" style="
              font-size:11px;font-weight:700;padding:2px 8px;border-radius:99px;
              background:rgba(245,158,11,0.18);color:#fbbf24;
              border:1px solid rgba(245,158,11,0.3);
            "></span>
          </div>
          <div id="alertEngineers" class="flex flex-wrap gap-1.5 mt-2"></div>
        </div>

        <!-- actions -->
        <div class="flex items-center gap-2 shrink-0 mt-0.5">
          <button id="alertRefreshBtn" onclick="triggerAlertCheck()" class="alert-refresh-btn">
            <span id="alertRefreshLabel">Refresh</span>
          </button>
          <button onclick="dismissAlert()" class="alert-dismiss-btn">Dismiss</button>
        </div>
      </div>
    </div>
  </div>
      <!-- HEADER -->
      <header class="flex items-center justify-between mb-7">
        <div>
          <h1 class="text-[22px] sm:text-[28px] font-extrabold text-white tracking-tight leading-none">Operations Dashboard</h1>
          <p class="text-[13px] text-white/30 font-medium mt-1">ReportoGeneral Contracting L.L.C.</p>
        </div>
        <div class="flex items-center gap-2">
          <button id="mFilterOpen" class="lg:hidden flex items-center gap-1.5 text-[13px] font-semibold text-white/50 hover:text-white bg-white/[0.04] border border-white/[0.07] rounded-[14px] px-3.5 py-2.5 transition active:scale-95">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
            Filter
          </button>
          <button id="exportBtn" class="flex items-center gap-1.5 text-[13px] font-bold bg-gold hover:bg-gold-light text-base-950 rounded-[14px] px-4 py-2.5 transition active:scale-95 shadow-lg shadow-gold/10">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Export Excel
          </button>
        </div>
      </header>

      <!-- DESKTOP TABS -->
      <nav class="hidden lg:flex items-center gap-1 mb-7 p-1.5 rounded-2xl bg-white/[0.02] border border-white/[0.04] w-fit">
        <button data-tab="overview" class="dtab on">Overview</button>
        <button data-tab="operations" class="dtab">⚙ Operations</button>
        <button data-tab="charts" class="dtab">Analytics</button>
        <button data-tab="reports" class="dtab">Reports</button>
        <button data-tab="table" class="dtab">Data Table</button>
      </nav>

      <!-- DESKTOP FILTERS -->
      <div id="deskFilters" class="hidden lg:block mb-7">
        <div class="panel px-5 py-4">
          <div class="grid grid-cols-4 xl:grid-cols-8 gap-3">
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-[0.1em] text-white/25 mb-1.5">From</label>
             <input type="date" id="fFromDate" class="fi" onclick="this.showPicker()">
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-[0.1em] text-white/25 mb-1.5">To</label>
              <input type="date" id="fToDate" class="fi" onclick="this.showPicker()">
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-[0.1em] text-white/25 mb-1.5">Project</label>
              <div style="display:flex;align-items:center;gap:6px">
                <select id="fProject" class="fi" style="background-color:#0d1528;color:#e2e8f0;flex:1" onchange="updateTimelineBtn(this)"><option value="">All</option><% filterOptions.projects.forEach(p => { %><option value="<%= p.id %>" data-name="<%= p.name %>"><%= p.name %></option><% }) %></select>
                <a id="timelineBtn" href="#" target="_blank" title="View Project Timeline" style="display:none;padding:6px 9px;border-radius:8px;border:1px solid rgba(201,168,76,0.25);background:rgba(201,168,76,0.07);color:#c9a84c;text-decoration:none;transition:all .18s;flex-shrink:0" onmouseover="this.style.background='rgba(201,168,76,0.15)'" onmouseout="this.style.background='rgba(201,168,76,0.07)'">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                </a>
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-[0.1em] text-white/25 mb-1.5">Engineer</label>
              <select id="fEngineer" class="fi" style="background-color:#0d1528;color:#e2e8f0"><option value="">All</option><% filterOptions.engineers.forEach(e => { %><option value="<%= e.id %>"><%= e.name %></option><% }) %></select>
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-[0.1em] text-white/25 mb-1.5">Activity</label>
              <select id="fActivity" class="fi" style="background-color:#0d1528;color:#e2e8f0"><option value="">All</option><% filterOptions.activities.forEach(a => { %><option value="<%= a %>"><%= a %></option><% }) %></select>
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-[0.1em] text-white/25 mb-1.5">Level</label>
              <select id="fLevel" class="fi" style="background-color:#0d1528;color:#e2e8f0"><option value="">All</option><% filterOptions.levels.forEach(l => { %><option value="<%= l %>"><%= l %></option><% }) %></select>
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-[0.1em] text-white/25 mb-1.5">Source</label>
              <select id="fSourceType" class="fi" style="background-color:#0d1528;color:#e2e8f0"><option value="">All</option><% filterOptions.sourceTypes.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %></select>
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-[0.1em] text-white/25 mb-1.5">Search</label>
              <input type="text" id="fSearch" class="fi" placeholder="Keyword...">
            </div>
          </div>
          <div class="flex items-center gap-2 mt-4">
            <button id="applyFilters" class="text-[13px] font-bold bg-gold hover:bg-gold-light text-base-950 rounded-xl px-6 py-2.5 transition">Apply</button>
            <button id="clearFilters" class="text-[13px] font-medium text-white/30 hover:text-white/60 border border-white/[0.08] hover:border-white/[0.15] rounded-xl px-5 py-2.5 transition">Clear</button>
          </div>
        </div>
      </div>

      <!-- LIMIT WARNING BANNER -->
      <div id="limitBanner" class="hidden mb-4 px-4 py-3 rounded-xl text-xs font-semibold"
        style="background:rgba(240,160,48,0.1);border:1px solid rgba(240,160,48,0.22);color:#f0a030;"></div>

      <!-- LOADING -->
      <div id="dashLoading" class="flex flex-col items-center justify-center py-32">
        <div class="w-10 h-10 border-[2.5px] border-gold/20 border-t-gold rounded-full animate-spin"></div>
        <p class="text-white/25 text-sm font-medium mt-5">Loading dashboard…</p>
      </div>

      <!-- CONTENT -->
      <div id="dashContent" class="hidden">

        <!-- OVERVIEW -->
        <section id="v-overview" class="view is-active space-y-7">
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
            <div class="kpi rise rise-1">
              <div class="w-10 h-10 rounded-[12px] bg-gold/10 flex items-center justify-center mb-3">
                <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              </div>
              <p class="text-[11px] font-semibold text-white/30 uppercase tracking-wide mb-1.5">Reports</p>
              <p class="kpi-num text-white" id="kpiReports">—</p>
            </div>
            <div class="kpi rise rise-2">
              <div class="w-10 h-10 rounded-[12px] bg-warn/10 flex items-center justify-center mb-3">
                <svg class="w-5 h-5 text-warn" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <p class="text-[11px] font-semibold text-white/30 uppercase tracking-wide mb-1.5">Activities</p>
              <p class="kpi-num text-warn" id="kpiActivities">—</p>
            </div>
            <div class="kpi rise rise-3">
              <div class="w-10 h-10 rounded-[12px] bg-ok/10 flex items-center justify-center mb-3">
                <svg class="w-5 h-5 text-ok" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <p class="text-[11px] font-semibold text-white/30 uppercase tracking-wide mb-1.5">Manpower</p>
              <p class="kpi-num text-ok" id="kpiManpower">—</p>
            </div>
            <div class="kpi rise rise-4">
              <div class="w-10 h-10 rounded-[12px] bg-info/10 flex items-center justify-center mb-3">
                <svg class="w-5 h-5 text-info" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              </div>
              <p class="text-[11px] font-semibold text-white/30 uppercase tracking-wide mb-1.5">Projects</p>
              <p class="kpi-num text-info" id="kpiProjects">—</p>
            </div>

          </div>



          <!-- ══════════════════════════════════════════════════
               MANPOWER BREAKDOWN SECTION
          ═══════════════════════════════════════════════════ -->
          <div id="manpowerSection" class="space-y-4">
            <p class="text-[11px] font-bold uppercase tracking-[0.1em] text-white/20">Manpower Breakdown</p>

            <!-- Row 1: Source cards -->
            <div class="grid grid-cols-3 gap-3" id="mpSourceCards">
              <div class="panel p-4">
                <p class="text-[10px] font-bold uppercase tracking-wide text-white/25 mb-2">In-House</p>
                <p class="text-2xl font-bold text-ok" id="mpInHouse">—</p>
                <!-- <p class="text-[11px] text-white/30 mt-1">عمالتك</p> -->
              </div>
              <div class="panel p-4">
                <p class="text-[10px] font-bold uppercase tracking-wide text-white/25 mb-2">Supplier</p>
                <p class="text-2xl font-bold text-info" id="mpSupplier">—</p>
                <!-- <p class="text-[11px] text-white/30 mt-1">سبلاير</p> -->
              </div>
              <div class="panel p-4">
                <p class="text-[10px] font-bold uppercase tracking-wide text-white/25 mb-2">Subcontractor</p>
                <p class="text-2xl font-bold text-warn" id="mpSubcontractor">—</p>
                <!-- <p class="text-[11px] text-white/30 mt-1">ساب كنتراكتور</p> -->
              </div>
            </div>

            <!-- Row 2: Trades + Companies side by side -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
              <!-- Trades breakdown -->
              <div class="panel p-5">
                <p class="text-[13px] font-bold text-white mb-4">Manpower by Trade</p>
                <div id="mpTradesTable" class="space-y-2.5"></div>
              </div>

              <!-- Per company breakdown -->
              <div class="panel p-5">
                <p class="text-[13px] font-bold text-white mb-4">External Companies</p>
                <div id="mpCompaniesTable" class="space-y-2"></div>
                <p id="mpNoCompanies" class="hidden text-[12px] text-white/20 text-center py-4">No external labor in selected period</p>
              </div>
            </div>
          </div>

          <!-- Project Comparison -->
          <div class="panel p-5">
            <div class="flex items-center justify-between mb-4">
              <p class="text-[13px] font-bold text-white">Manpower by Project</p>
              <span class="text-[10px] font-semibold uppercase tracking-wide text-white/20">In-House · Supplier · Sub-Con · per company</span>
            </div>
            <div id="mpProjectComparison" class="space-y-2"></div>
          </div>

          <div class="panel p-5">
            <div class="flex items-center justify-between mb-5">
              <p class="text-[13px] font-bold text-white">Project Overview</p>
              <span class="text-[10px] font-semibold uppercase tracking-wide text-white/20">Manpower by Project</span>
            </div>
            <div style="height: 280px;"><canvas id="chartCombo1"></canvas></div>
          </div>
        </section>

        <!-- CHARTS -->
        <section id="v-charts" class="view space-y-4">

          <!-- Row 1: Engineer Workload + Labor Source Mix -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div class="panel p-5">
              <p class="text-[13px] font-bold text-white mb-1">Engineer Workload</p>
              <p class="text-[11px] text-gray-500 mb-4">Total activities logged per engineer</p>
              <div style="height:280px"><canvas id="chartEngineer"></canvas></div>
            </div>
            <div class="panel p-5">
              <p class="text-[13px] font-bold text-white mb-1">Labor Source Mix</p>
              <p class="text-[11px] text-gray-500 mb-4">Total workers by source type</p>
              <div style="height:280px"><canvas id="chartSource"></canvas></div>
            </div>
          </div>

          <!-- Row 3: Labor Analytics deep-dive -->
          <div class="panel p-5">
            <div class="flex items-center justify-between mb-1">
              <div>
                <p class="text-[13px] font-bold text-white">Labor Source Analytics</p>
                <p class="text-[11px] text-gray-500 mt-0.5">Detailed breakdown of workforce distribution across labor sources</p>
              </div>
              <!-- Sub-tabs -->
              <div class="flex gap-1 bg-white/5 rounded-lg p-1" id="laborTabBtns">
                <button class="labor-tab-btn active" data-ltab="trades" style="padding:5px 12px;border-radius:6px;font-size:11px;font-weight:600;border:none;cursor:pointer;transition:all .2s;background:rgba(201,168,76,0.15);color:#c9a84c">Trade Mix</button>
                <button class="labor-tab-btn" data-ltab="projects" style="padding:5px 12px;border-radius:6px;font-size:11px;font-weight:600;border:none;cursor:pointer;transition:all .2s;background:transparent;color:#64748b">By Project</button>
                <button class="labor-tab-btn" data-ltab="trend" style="padding:5px 12px;border-radius:6px;font-size:11px;font-weight:600;border:none;cursor:pointer;transition:all .2s;background:transparent;color:#64748b">Daily Trend</button>
              </div>
            </div>

            <!-- Trade Mix tab -->
            <div id="ltab-trades" class="labor-tab-panel mt-4">
              <div style="height:300px"><canvas id="chartTrades"></canvas></div>
            </div>

            <!-- By Project tab -->
            <div id="ltab-projects" class="labor-tab-panel mt-4" style="display:none">
              <div style="height:320px"><canvas id="chartProjectSources"></canvas></div>
            </div>

            <!-- Daily Trend tab -->
            <div id="ltab-trend" class="labor-tab-panel mt-4" style="display:none">
              <div style="height:300px"><canvas id="chartLaborTrend"></canvas></div>
            </div>
          </div>

        </section>

        <!-- REPORTS -->
        <section id="v-reports" class="view space-y-4">
          <div class="flex items-center justify-between">
            <p class="text-[13px] font-bold text-white">Daily Reports</p>
            <span id="reportsCountBadge" class="text-[11px] font-bold px-3 py-1.5 rounded-full bg-white/[0.04] text-white/30 border border-white/[0.05]">0</span>
          </div>
          <div id="groupedReportsContainer" class="space-y-3"></div>
        </section>


        <!-- OPERATIONS WORKFORCE PANEL -->
        <section id="v-operations" class="view space-y-4">

          <!-- Header -->
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div>
              <p class="text-[15px] font-extrabold text-white tracking-tight">Workforce Detail</p>
              <p class="text-[12px] text-white/30 mt-0.5">Workers per project · activity · element · trade</p>
            </div>
            <div id="opsTotalBadge" class="flex items-center gap-2.5 px-4 py-2.5 rounded-2xl bg-white/[0.04] border border-white/[0.06] w-fit">
              <span class="text-[10px] text-white/25 font-bold uppercase tracking-widest">Total Workers</span>
              <span id="opsTotalNum" class="text-[22px] font-extrabold text-gold leading-none">—</span>
            </div>
          </div>

          <!-- Project selector pills -->
          <div id="opsProjPills" class="flex gap-2 flex-wrap"></div>

          <!-- Activities container -->
          <div id="opsActivitiesContainer" class="space-y-3"></div>

          <!-- Empty -->
          <div id="opsEmpty" class="hidden text-center py-20 text-white/20">
            <svg class="w-10 h-10 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <p class="text-[13px] font-semibold">No workforce data for selected filters</p>
          </div>

        </section>

        <!-- TABLE -->
        <section id="v-table" class="view space-y-4">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <p class="text-[13px] font-bold text-white">Activity Details</p>
            <input type="text" id="tableSearch" class="fi sm:max-w-[300px]" placeholder="Quick filter…">
          </div>
          <div class="panel overflow-hidden">
            <div class="overflow-x-auto" style="max-height: 75vh;">
              <table class="dtable w-full">
                <thead>
                  <tr>
                    <th class="px-4 py-3 text-left">Report ID</th>
                    <th class="px-4 py-3 text-left">Date</th>
                    <th class="px-4 py-3 text-left">Shift</th>
                    <th class="px-4 py-3 text-left">Time</th>
                    <th class="px-4 py-3 text-left">Engineer</th>
                    <th class="px-4 py-3 text-left">Site</th>
                    <th class="px-4 py-3 text-left">#</th>
                    <th class="px-4 py-3 text-left">Element</th>
                    <th class="px-4 py-3 text-left">Level</th>
                    <th class="px-4 py-3 text-left">Activity</th>
                    <th class="px-4 py-3 text-left">Progress</th>
                    <th class="px-4 py-3 text-left">MP</th>
                    <th class="px-4 py-3 text-left">Source</th>
                    <th class="px-4 py-3 text-left">Company</th>
                  </tr>
                </thead>
                <tbody id="detailTableBody" class="divide-y divide-white/[0.03]"></tbody>
              </table>
            </div>
            <div id="tableEmpty" class="hidden text-center py-16 text-white/20 text-sm font-medium">No data to display</div>
          </div>
        </section>
      </div>
    </div>
  </main>

  <!-- MOBILE FILTER SHEET -->
  <div id="sheetBg" class="sheet-bg"></div>

  <div id="sheet" class="sheet">
    <div class="sheet-handle"></div>

    <div class="mobile-sheet-content">
      <div class="flex items-center justify-between mb-4">
        <p class="text-[15px] font-bold text-white">Filters</p>

        <button id="sheetClose" class="text-white/30 hover:text-white p-2 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <div class="mobile-filter-grid">
        <div>
          <label class="m-label">From</label>
          <input type="date" id="mFromDate" class="fi">
        </div>

        <div>
          <label class="m-label">To</label>
          <input type="date" id="mToDate" class="fi">
        </div>

        <div class="mobile-full">
          <label class="m-label">Project</label>
          <select id="mProject" class="fi">
            <option value="">All Projects</option>
            <% filterOptions.projects.forEach(p => { %>
              <option value="<%= p.id %>"><%= p.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="mobile-full">
          <label class="m-label">Engineer</label>
          <select id="mEngineer" class="fi">
            <option value="">All Engineers</option>
            <% filterOptions.engineers.forEach(e => { %>
              <option value="<%= e.id %>"><%= e.name %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="m-label">Activity</label>
          <select id="mActivity" class="fi">
            <option value="">All</option>
            <% filterOptions.activities.forEach(a => { %>
              <option value="<%= a %>"><%= a %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="m-label">Level</label>
          <select id="mLevel" class="fi">
            <option value="">All</option>
            <% filterOptions.levels.forEach(l => { %>
              <option value="<%= l %>"><%= l %></option>
            <% }) %>
          </select>
        </div>

        <div class="mobile-full">
          <label class="m-label">Source</label>
          <select id="mSourceType" class="fi">
            <option value="">All Sources</option>
            <% filterOptions.sourceTypes.forEach(s => { %>
              <option value="<%= s %>"><%= s %></option>
            <% }) %>
          </select>
        </div>

        <div class="mobile-full">
          <label class="m-label">Search</label>
          <input type="text" id="mSearch" class="fi" placeholder="Keyword…">
        </div>
      </div>

      <div class="mobile-filter-actions">
        <button id="mApply" class="mobile-apply-btn">Apply Filters</button>
        <button id="mClear" class="mobile-clear-btn">Clear</button>
      </div>
    </div>
  </div>

  <!-- BOTTOM NAV -->
  <nav class="bnav lg:hidden">
    <div class="flex">
      <button class="bnav-btn on" data-tab="overview">
        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v5a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM14 5a1 1 0 011-1h4a1 1 0 011 1v2a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 16a1 1 0 011-1h4a1 1 0 011 1v3a1 1 0 01-1 1H5a1 1 0 01-1-1v-3zM14 13a1 1 0 011-1h4a1 1 0 011 1v6a1 1 0 01-1 1h-4a1 1 0 01-1-1v-6z"/></svg>
        <span>Overview</span>
      </button>
      <button class="bnav-btn" data-tab="operations">
        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span>Ops</span>
      </button>
      <button class="bnav-btn" data-tab="charts">
        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        <span>Analytics</span>
      </button>
      <button class="bnav-btn" data-tab="reports">
        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <span>Reports</span>
      </button>
      <button class="bnav-btn" data-tab="table">
        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        <span>Table</span>
      </button>
    </div>
  </nav>

  <script>
    // Injected by server — controls alert visibility without extra API round-trip
    window.SITE_CONFIG = window.SITE_CONFIG || {};
    <%
      const _u = typeof adminUser !== 'undefined' ? adminUser : null;
      const _canAlert = _u && (
        _u.role === 'superadmin' ||
        _u.permissions?.canViewAlerts === true
      );
    %>
    <% var _alertVal = _canAlert ? 'true' : 'false'; %>
window.SITE_CONFIG.canViewAlerts = <%- _alertVal %>;
    // Project ID map for timeline links
    window.PROJECT_ID_MAP = {};
   <% filterOptions.projects.forEach(p => { %>window.PROJECT_ID_MAP[<%- JSON.stringify(p.name) %>] = <%- JSON.stringify(p.id) %>;<% }) %>
  </script>
  <script src="/js/dashboard.js"></script>
  <script src="/js/dashboard-manpower.js"></script>
  

</body>
</html>
