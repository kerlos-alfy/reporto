<!DOCTYPE html>
<html lang="en" data-theme="<%= (typeof adminUser !== 'undefined' && adminUser && adminUser.theme) ? adminUser.theme : 'navy' %>">
<head>
  <!-- Theme: apply before render to prevent flash -->
  <script>
    (function(){var t=localStorage.getItem('ag_theme');if(t&&['navy','cyan','amber'].includes(t)){document.documentElement.setAttribute('data-theme',t);if(t==='light')document.documentElement.classList.remove('dark');else document.documentElement.classList.add('dark');}})();
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/logo.png">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/images/logo.png">
<link rel="apple-touch-icon" href="/assets/images/logo.png">
  <title>Dashboard — Agile Prime</title>

  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            base: {
              950: 'var(--surface-950)',
              900: 'var(--surface-900)',
              850: 'var(--surface-850)',
              800: 'var(--surface-800)',
              700: 'var(--surface-700)',
              600: 'var(--surface-700)',
            },
            gold: {
              DEFAULT: 'var(--accent)',
              light: 'var(--accent-light)',
              dim:   'var(--accent-dim)',
            },
            ok: '#3dd68c',
            warn: '#f0a030',
            bad: '#f05555',
            info: '#50b0f0',
          },
          fontFamily: {
            sans: ['DM Sans', 'system-ui', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace'],
          },
        },
      },
    };
  </script>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
  <link rel="stylesheet" href="/css/app.css">

  <style>
  *, *::before, *::after { box-sizing: border-box; }

  body {
    background: #080a10;
    color: #c8cdd6;
    font-family: 'DM Sans', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  ::-webkit-scrollbar { width: 5px; height: 5px; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 99px; }

  .panel {
    background: #10151f;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
  }

  .view { display: none; }
  .view.is-active { display: block; }

  /* Bottom Nav */
  .bnav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(8,10,16,0.94);
    backdrop-filter: blur(24px) saturate(1.5);
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-bottom: env(safe-area-inset-bottom, 0);
  }

  .bnav-btn {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 10px 2px 8px;
    font-size: 10px;
    font-weight: 600;
    color: rgba(255,255,255,0.28);
    transition: 0.2s;
    -webkit-tap-highlight-color: transparent;
    letter-spacing: 0.02em;
    background: none;
    border: none;
    cursor: pointer;
  }

  .bnav-btn.on { color: #c9a84c; }
  .bnav-btn:active { transform: scale(0.9); }
  .bnav-btn svg { width: 24px; height: 24px; }

  /* Filter Sheet */
  .sheet-bg {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(3px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }

  .sheet-bg.on {
    opacity: 1;
    pointer-events: auto;
  }

  .sheet {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 201;
    background: #10151f;
    border-top-left-radius: 28px;
    border-top-right-radius: 28px;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(.22,.68,0,1.0);
    max-height: 88vh;
    overflow-y: auto;
    border: 1px solid rgba(255,255,255,0.06);
    border-bottom: 0;
  }

  .sheet.on { transform: translateY(0); }

  .sheet-handle {
    width: 40px;
    height: 5px;
    border-radius: 99px;
    background: rgba(255,255,255,0.12);
    margin: 14px auto 8px;
  }

  /* Inputs */
  .fi {
    width: 100%;
    background: #0d1528;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 10px 36px 10px 14px;
    font-size: 13px;
    color: #e0e4ea;
    outline: none;
    transition: border-color 0.2s, background-color 0.2s, box-shadow 0.2s;
    font-family: 'DM Sans', sans-serif;
  }

  select.fi {
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%23c9a84c' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
    padding-right: 36px;
  }

  input[type="date"].fi {
    appearance: auto;
    -webkit-appearance: auto;
    background-image: none;
    padding-right: 12px;
    color-scheme: dark;
    min-height: 44px;
  }

  input[type="date"].fi::-webkit-calendar-picker-indicator {
    cursor: pointer;
    opacity: 0.9;
    filter: invert(78%) sepia(25%) saturate(523%) hue-rotate(7deg) brightness(92%) contrast(87%);
  }

  input[type="date"].fi::-webkit-datetime-edit,
  input[type="date"].fi::-webkit-datetime-edit-text,
  input[type="date"].fi::-webkit-datetime-edit-month-field,
  input[type="date"].fi::-webkit-datetime-edit-day-field,
  input[type="date"].fi::-webkit-datetime-edit-year-field {
    color: #e0e4ea;
  }

  .fi:hover {
    border-color: rgba(201,168,76,0.2);
    background-color: #0f1a30;
  }

  .fi:focus {
    border-color: rgba(212,168,67,0.5);
    box-shadow: 0 0 0 3px rgba(201,168,76,0.07);
  }

  .fi::placeholder { color: rgba(255,255,255,0.2); }
  .fi option { background-color: #0d1528; color: #e2e8f0; }

  /* KPI */
  .kpi {
    background: linear-gradient(160deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    padding: 20px;
  }

  .kpi-num {
    font-size: 32px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  @media (max-width: 639px) {
    .kpi-num { font-size: 26px; }
  }

  /* Insight scroll */
  .insight-row {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 2px 0 8px;
  }

  .insight-row::-webkit-scrollbar { display: none; }

  .insight-item {
    scroll-snap-align: start;
    flex-shrink: 0;
    min-width: 170px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 14px;
    padding: 14px 16px;
  }

  /* Report card */
  .rcard {
    background: #10151f;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 18px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .rcard:hover { border-color: rgba(255,255,255,0.10); }

  /* Progress bar */
  .pbar {
    height: 5px;
    border-radius: 99px;
    background: rgba(255,255,255,0.06);
  }

  .pbar-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 0.5s ease;
  }

  /* Status dot */
  .sdot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    display: inline-block;
  }

  /* Table */
  .dtable {
    font-size: 13px;
    font-family: 'DM Sans', sans-serif;
  }

  .dtable th {
    position: sticky;
    top: 0;
    z-index: 2;
    background: #151c28;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .dtable td { color: rgba(255,255,255,0.65); }
  .dtable tbody tr:hover td { background: rgba(255,255,255,0.025); }

  /* Desktop tab */
  .dtab {
    font-size: 13px;
    font-weight: 600;
    padding: 9px 20px;
    border-radius: 14px;
    color: rgba(255,255,255,0.3);
    transition: all 0.2s;
    cursor: pointer;
    border: none;
    background: transparent;
  }

  .dtab:hover { color: rgba(255,255,255,0.5); }
  .dtab.on { background: rgba(255,255,255,0.07); color: #fff; }

  /* Fade */
  @keyframes rise {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .rise { animation: rise 0.45s ease both; }
  .rise-1 { animation-delay: 0.04s; }
  .rise-2 { animation-delay: 0.08s; }
  .rise-3 { animation-delay: 0.12s; }
  .rise-4 { animation-delay: 0.16s; }
  .rise-5 { animation-delay: 0.20s; }

  @media (min-width: 1024px) {
    .bnav { display: none; }
  }

  @media (max-width: 1023px) {
    body { padding-bottom: 68px; }
  }

  /* DAILY REPORTS */
  .rpt-date-group { margin-bottom: 32px; }
  .rpt-date-group:last-child { margin-bottom: 0; }

  .rpt-date-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
    padding: 0 2px;
  }

  .rpt-date-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    font-weight: 700;
    color: rgba(255,255,255,0.6);
    letter-spacing: -0.01em;
  }

  .rpt-date-badge svg { color: #c9a84c; }

  .rpt-date-stats {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    font-weight: 500;
    color: rgba(255,255,255,0.2);
  }

  .rpt-date-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
  }

  .rpt-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  @media (min-width: 768px) {
    .rpt-cards-grid { grid-template-columns: repeat(2,1fr); }
  }

  @media (min-width: 1280px) {
    .rpt-cards-grid { grid-template-columns: repeat(3,1fr); }
  }

  .nc-card {
    background: #10151f;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .nc-card:hover { border-color: rgba(255,255,255,0.11); }
  .nc-card--delayed { border-left: 3px solid #f05555; }

  .nc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px 0;
  }

  .nc-id {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #c9a84c;
    background: rgba(212,168,67,0.08);
    padding: 3px 8px;
    border-radius: 6px;
  }

  .nc-badge {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 3px 9px;
    border-radius: 5px;
  }

  .nc-badge--ok   { background: rgba(61,214,140,0.1); color: #3dd68c; }
  .nc-badge--warn { background: rgba(240,160,48,0.1); color: #f0a030; }
  .nc-badge--bad  { background: rgba(240,85,85,0.1); color: #f05555; }

  .nc-project {
    font-size: 18px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.025em;
    line-height: 1.2;
    padding: 10px 16px 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nc-eng {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 6px 16px 14px;
  }

  .nc-eng-av {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(212,168,67,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    font-weight: 800;
    color: #c9a84c;
    flex-shrink: 0;
  }

  .nc-eng-name {
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.35);
  }

  /* النسخة النهائية فقط */
  .nc-shift-row {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 8px;
    padding: 6px 16px 10px;
    overflow: hidden;
  }

  .nc-shift-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .nc-shift-badge svg { flex-shrink: 0; }

  .nc-shift-badge--day {
    background: rgba(201,168,76,0.12);
    color: #c9a84c;
    border: 1px solid rgba(201,168,76,0.2);
  }

  .nc-shift-badge--night {
    background: rgba(99,102,241,0.12);
    color: #a5b4fc;
    border: 1px solid rgba(99,102,241,0.2);
  }

  .nc-shift-sep {
    width: 1px;
    height: 14px;
    background: rgba(255,255,255,0.08);
    flex-shrink: 0;
  }

  .nc-shift-time {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nc-shift-time svg {
    flex-shrink: 0;
    color: rgba(201,168,76,0.5);
  }

  .nc-shift-dur {
    font-size: 11px;
    font-weight: 600;
    color: rgba(201,168,76,0.7);
    white-space: nowrap;
  }

  .nc-divider {
    height: 1px;
    background: rgba(255,255,255,0.05);
  }

  .nc-stats {
    display: flex;
    align-items: center;
    padding: 14px 16px;
    gap: 0;
  }

  .nc-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .nc-stat-n {
    font-size: 22px;
    font-weight: 800;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .nc-stat-l {
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: rgba(255,255,255,0.18);
  }

  .nc-stat-sep {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,0.05);
    margin: 0 16px;
    flex-shrink: 0;
  }

  .nc-minibar-wrap { padding: 0 16px 14px; }

  .nc-minibar {
    display: flex;
    height: 4px;
    border-radius: 99px;
    overflow: hidden;
    gap: 2px;
    margin-bottom: 6px;
  }

  .nc-seg { border-radius: 99px; min-width: 4px; }
  .nc-seg--ok { background: #3dd68c; }
  .nc-seg--warn { background: #f0a030; }
  .nc-seg--bad { background: #f05555; }

  .nc-minibar-legend { display: flex; gap: 10px; }
  .nc-leg { font-size: 10px; font-weight: 600; }
  .nc-leg--ok { color: rgba(61,214,140,0.6); }
  .nc-leg--warn { color: rgba(240,160,48,0.6); }
  .nc-leg--bad { color: rgba(240,85,85,0.6); }

  .nc-alert {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin: 0 16px 12px;
    background: rgba(240,85,85,0.05);
    border: 1px solid rgba(240,85,85,0.12);
    border-radius: 10px;
    padding: 9px 12px;
    font-size: 11px;
    line-height: 1.5;
    color: rgba(240,110,110,0.85);
  }

  .nc-alert svg {
    flex-shrink: 0;
    color: #f05555;
    margin-top: 1px;
  }

  .nc-comment {
    font-size: 11px;
    color: rgba(255,255,255,0.25);
    line-height: 1.5;
    margin: 0 16px 12px;
    padding-left: 10px;
    border-left: 2px solid rgba(255,255,255,0.06);
  }

  .nc-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 11px 16px;
    background: transparent;
    border: none;
    border-top: 1px solid rgba(255,255,255,0.05);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
  }

  .nc-toggle:hover {
    color: rgba(255,255,255,0.5);
    background: rgba(255,255,255,0.02);
  }

  .nc-toggle .rchev {
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  .nc-items {
    border-top: 1px solid rgba(255,255,255,0.05);
    padding: 10px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .nc-item {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 10px;
    padding: 11px 12px;
  }

  .nc-item-row {
    display: flex;
    align-items: center;
    gap: 9px;
    margin-bottom: 8px;
  }

  .nc-item-num {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    color: rgba(255,255,255,0.3);
    flex-shrink: 0;
  }

  .nc-item-info { flex: 1; min-width: 0; }

  .nc-item-name {
    display: block;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nc-item-sub {
    display: block;
    font-size: 10px;
    color: rgba(255,255,255,0.28);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 1px;
  }

  .nc-item-pct {
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.03em;
    flex-shrink: 0;
  }

  .nc-item-pct--ok { color: #3dd68c; }
  .nc-item-pct--warn { color: #f0a030; }
  .nc-item-pct--bad { color: #f05555; }

  .nc-item-bar {
    height: 3px;
    border-radius: 99px;
    background: rgba(255,255,255,0.05);
    overflow: hidden;
    margin-bottom: 9px;
  }

  .nc-item-bar-fill { height: 100%; border-radius: 99px; }
  .nc-item-bar-fill--ok { background: #3dd68c; }
  .nc-item-bar-fill--warn { background: #f0a030; }
  .nc-item-bar-fill--bad { background: #f05555; }

  .nc-item-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .nc-tag {
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 7px;
    border-radius: 4px;
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.28);
  }

  .nc-tag--ext { background: rgba(80,176,240,0.08); color: #50b0f0; }
  .nc-tag--co { background: rgba(167,139,250,0.08); color: #a78bfa; }

  .nc-item-note {
    font-size: 10px;
    color: rgba(255,255,255,0.22);
    font-style: italic;
    margin-top: 7px;
    line-height: 1.4;
    padding-left: 8px;
    border-left: 2px solid rgba(255,255,255,0.06);
  }

  .rpt-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    gap: 12px;
    color: rgba(255,255,255,0.15);
  }

  .rpt-empty p {
    font-size: 14px;
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .nc-project { font-size: 16px; }
    .nc-stat-n { font-size: 19px; }
    .nc-stat-sep { margin: 0 10px; }
    .nc-toggle { padding: 13px 16px; }
  }

  /* OPERATIONS — Workforce Detail */
  .ops-proj-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border-radius: 99px;
    cursor: pointer;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.01em;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
    color: rgba(255,255,255,0.4);
    transition: all 0.2s;
    white-space: nowrap;
  }

  .ops-proj-pill:hover {
    border-color: rgba(201,168,76,0.3);
    color: rgba(255,255,255,0.7);
  }

  .ops-proj-pill.active {
    background: rgba(201,168,76,0.12);
    border-color: rgba(201,168,76,0.4);
    color: #c9a84c;
  }

  .ops-proj-pill .pill-count {
    font-size: 10px;
    font-weight: 800;
    background: rgba(255,255,255,0.08);
    border-radius: 99px;
    padding: 1px 6px;
    color: rgba(255,255,255,0.3);
  }

  .ops-proj-pill.active .pill-count {
    background: rgba(201,168,76,0.2);
    color: #c9a84c;
  }

  .ops-act-card {
    background: #10151f;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 18px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .ops-act-card:hover { border-color: rgba(255,255,255,0.1); }

  .ops-act-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    cursor: pointer;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .ops-act-header:active { opacity: 0.8; }

  .ops-act-name {
    font-size: 14px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .ops-act-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .ops-meta-tag {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 5px;
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.35);
  }

  .ops-meta-tag.element { background: rgba(80,176,240,0.08); color: rgba(80,176,240,0.7); }
  .ops-meta-tag.level { background: rgba(167,139,250,0.08); color: rgba(167,139,250,0.7); }
  .ops-meta-tag.prog-ok { background: rgba(61,214,140,0.08); color: #3dd68c; }
  .ops-meta-tag.prog-warn { background: rgba(240,160,48,0.08); color: #f0a030; }
  .ops-meta-tag.prog-bad { background: rgba(240,85,85,0.08); color: #f05555; }

  .ops-act-total {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    flex-shrink: 0;
  }

  .ops-act-total-num {
    font-size: 26px;
    font-weight: 900;
    color: #c9a84c;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .ops-act-total-lbl {
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.2);
  }

  .ops-src-strip {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 6px;
  }

  .ops-src-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 7px;
  }

  .ops-src-chip .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .ops-act-body {
    border-top: 1px solid rgba(255,255,255,0.05);
    padding: 16px 20px;
    display: none;
  }

  .ops-trade-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 8px;
    margin-top: 12px;
  }

  .ops-trade-cell {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 10px;
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .ops-trade-num {
    font-size: 20px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .ops-trade-lbl {
    font-size: 10px;
    color: rgba(255,255,255,0.3);
    font-weight: 500;
  }

  .ops-company-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 8px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.5);
  }

  .ops-company-chip b { color: #c9a84c; }

  .ops-chevron {
    transition: transform 0.25s ease;
    color: rgba(255,255,255,0.2);
    flex-shrink: 0;
  }

  .ops-act-card.open .ops-chevron { transform: rotate(180deg); }
  .ops-act-card.open .ops-act-body { display: block; }

  /* Alert banner */
  @keyframes bannerIn {
    from { opacity: 0; transform: translateY(-12px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes pulse-ring {
    0% { box-shadow: 0 0 0 0 rgba(245,158,11,0.35); }
    70% { box-shadow: 0 0 0 10px rgba(245,158,11,0); }
    100% { box-shadow: 0 0 0 0 rgba(245,158,11,0); }
  }

  #alertBanner { animation: bannerIn 0.4s cubic-bezier(.22,.68,0,1.2) both; }
  #alertBanner .alert-icon { animation: pulse-ring 2s ease-out infinite; }

  .alert-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.02em;
    padding: 3px 10px 3px 6px;
    border-radius: 99px;
    background: rgba(245,158,11,0.12);
    color: #fbbf24;
    border: 1px solid rgba(245,158,11,0.2);
  }

  .alert-chip::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #f59e0b;
    flex-shrink: 0;
  }

  .alert-dismiss-btn {
    font-size: 12px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.35);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .alert-dismiss-btn:hover {
    color: rgba(255,255,255,0.6);
    border-color: rgba(255,255,255,0.15);
  }

  .alert-refresh-btn {
    font-size: 12px;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 10px;
    border: 1px solid rgba(245,158,11,0.3);
    color: #fbbf24;
    background: rgba(245,158,11,0.08);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .alert-refresh-btn:hover { background: rgba(245,158,11,0.15); }
  .alert-refresh-btn:disabled { opacity: 0.5; cursor: not-allowed; }


  /* =========================
     MOBILE RESPONSIVE FIXES
  ========================= */

  html,
  body {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
  }

  main {
    max-width: 100%;
    overflow-x: hidden;
  }

  .mobile-sheet-content {
    padding: 12px 20px 32px;
  }

  .mobile-filter-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .mobile-full {
    grid-column: 1 / -1;
  }

  .m-label {
    display: block;
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.25);
    margin-bottom: 6px;
  }

  .mobile-filter-actions {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 10px;
    margin-top: 18px;
    position: sticky;
    bottom: 0;
    background: linear-gradient(to top, #10151f 70%, rgba(16,21,31,0));
    padding-top: 18px;
    padding-bottom: env(safe-area-inset-bottom, 0);
  }

  .mobile-apply-btn {
    width: 100%;
    border: none;
    border-radius: 14px;
    background: #c9a84c;
    color: #080a10;
    font-size: 13px;
    font-weight: 800;
    padding: 13px 16px;
    cursor: pointer;
  }

  .mobile-clear-btn {
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    background: rgba(255,255,255,0.03);
    color: rgba(255,255,255,0.45);
    font-size: 13px;
    font-weight: 700;
    padding: 13px 16px;
    cursor: pointer;
  }

  @media (max-width: 639px) {
    main {
      padding-left: 12px !important;
      padding-right: 12px !important;
      padding-top: 72px !important;
    }

    header {
      align-items: flex-start !important;
      gap: 12px;
    }

    header h1 {
      font-size: 20px !important;
      line-height: 1.15 !important;
    }

    header p {
      font-size: 12px !important;
    }

    #exportBtn,
    #mFilterOpen {
      width: 42px;
      height: 42px;
      padding: 0 !important;
      justify-content: center;
      flex-shrink: 0;
      font-size: 0 !important;
    }

    #exportBtn svg,
    #mFilterOpen svg {
      width: 18px;
      height: 18px;
    }

    .panel {
      border-radius: 18px;
    }

    .kpi {
      padding: 14px !important;
      border-radius: 18px;
    }

    .kpi .w-10 {
      width: 34px !important;
      height: 34px !important;
    }

    .kpi-num {
      font-size: 24px !important;
    }

    #mpSourceCards {
      grid-template-columns: 1fr !important;
    }

    #mpSourceCards .panel {
      padding: 16px !important;
    }

    #mpProjectComparison,
    #mpTradesTable,
    #mpCompaniesTable {
      overflow-x: hidden;
    }

    .rpt-date-header {
      align-items: flex-start;
      gap: 8px;
      flex-direction: column;
    }

    .nc-card {
      border-radius: 18px;
    }

    .nc-top,
    .nc-project,
    .nc-eng,
    .nc-shift-row,
    .nc-stats,
    .nc-minibar-wrap {
      padding-left: 14px !important;
      padding-right: 14px !important;
    }

    .nc-project {
      white-space: normal !important;
      overflow: visible !important;
      text-overflow: unset !important;
      line-height: 1.25 !important;
    }

    .nc-shift-row {
      flex-wrap: wrap !important;
      overflow: visible !important;
    }

    .nc-shift-sep {
      display: none;
    }

    .nc-shift-time,
    .nc-shift-dur {
      font-size: 10px !important;
    }

    .nc-stats {
      gap: 10px;
    }

    .nc-stat-sep {
      margin: 0 4px !important;
    }

    .ops-act-header {
      padding: 14px !important;
      gap: 12px;
    }

    .ops-act-name {
      font-size: 13px !important;
    }

    .ops-act-total-num {
      font-size: 22px !important;
    }

    .ops-trade-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }

    .dtable {
      min-width: 1050px;
    }

    #alertBanner .flex.items-start {
      flex-direction: column;
    }

    #alertBanner .alert-icon {
      width: 38px !important;
      height: 38px !important;
    }

    #alertBanner .flex.items-center.gap-2.shrink-0 {
      width: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
    }

    .alert-refresh-btn,
    .alert-dismiss-btn {
      flex: 1;
      min-width: 120px;
    }
  }

  @media (max-width: 380px) {
    .mobile-filter-grid {
      grid-template-columns: 1fr;
    }

    .mobile-full {
      grid-column: auto;
    }

    .ops-trade-grid {
      grid-template-columns: 1fr !important;
    }
  }

</style>


