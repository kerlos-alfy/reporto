<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/logo.png">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/images/logo.png">
<link rel="apple-touch-icon" href="/assets/images/logo.png">
  <title>User Management — Agile Prime</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            base: { 950:'#080a10', 900:'#0c1017', 850:'#10151f', 800:'#151c28', 700:'#1e2738', 600:'#2a3548' },
            gold: { DEFAULT:'#c9a84c', light:'#e2c97e', dim:'#8a7230' },
          },
          fontFamily: { sans:['DM Sans','system-ui','sans-serif'], mono:['JetBrains Mono','monospace'] },
        },
      },
    };
  </script>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { background:#080a10; color:#c8cdd6; font-family:'DM Sans',system-ui,sans-serif; -webkit-font-smoothing:antialiased; }
    ::-webkit-scrollbar { width:5px; height:5px; }
    ::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.08); border-radius:99px; }
    .panel { background:#10151f; border:1px solid rgba(255,255,255,0.06); border-radius:16px; }
  </style>
</head>
<body class="min-h-screen">

  <%- include('../../partials/navbar') %>

  <!-- Flash Messages -->
  <% if (typeof flash !== 'undefined' && flash.success) { %>
    <div id="flash-success" class="fixed top-20 right-4 z-50 max-w-sm bg-emerald-600/90 backdrop-blur-md text-white px-5 py-3 rounded-xl shadow-2xl text-sm font-medium border border-white/10"><%= flash.success %></div>
  <% } %>
  <% if (typeof flash !== 'undefined' && flash.error) { %>
    <div id="flash-error" class="fixed top-20 right-4 z-50 max-w-sm bg-red-600/90 backdrop-blur-md text-white px-5 py-3 rounded-xl shadow-2xl text-sm font-medium border border-white/10"><%= flash.error %></div>
  <% } %>

  <main class="pt-20 sm:pt-[88px]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white">User Management</h1>
        <p class="text-gray-400 text-sm mt-1">Manage system users and their permissions</p>
      </div>
      <a href="/admin/users/new"
         class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-base-950 font-semibold text-sm px-5 py-2.5 rounded-xl transition-all shadow-lg">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Add New User
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <% const total = users.length; %>
      <% const active = users.filter(u => u.isActive).length; %>
      <% const admins = users.filter(u => u.role === 'admin').length; %>
      <% const viewers = users.filter(u => u.role === 'viewer').length; %>
      <div class="panel p-4">
        <div class="text-2xl font-bold text-white"><%= total %></div>
        <div class="text-xs text-gray-400 mt-1">Total Users</div>
      </div>
      <div class="panel p-4">
        <div class="text-2xl font-bold text-emerald-400"><%= active %></div>
        <div class="text-xs text-gray-400 mt-1">Active</div>
      </div>
      <div class="panel p-4">
        <div class="text-2xl font-bold text-blue-400"><%= admins %></div>
        <div class="text-xs text-gray-400 mt-1">Admins</div>
      </div>
      <div class="panel p-4">
        <div class="text-2xl font-bold text-purple-400"><%= viewers %></div>
        <div class="text-xs text-gray-400 mt-1">Viewers</div>
      </div>
    </div>

    <!-- Table -->
    <div class="panel overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10" style="background:rgba(255,255,255,0.03)">
              <th class="text-left px-5 py-4 text-gray-400 font-medium">User</th>
              <th class="text-left px-5 py-4 text-gray-400 font-medium hidden md:table-cell">Role</th>
              <th class="text-left px-5 py-4 text-gray-400 font-medium hidden lg:table-cell">Permissions</th>
              <th class="text-left px-5 py-4 text-gray-400 font-medium hidden lg:table-cell">Engineer / Projects</th>
              <th class="text-left px-5 py-4 text-gray-400 font-medium hidden sm:table-cell">Status</th>
              <th class="text-left px-5 py-4 text-gray-400 font-medium hidden lg:table-cell">Created</th>
              <th class="px-5 py-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <% for (const user of users) { %>
            <tr class="hover:bg-white/[0.02] transition-colors">
              <!-- Name -->
              <td class="px-5 py-4">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold shrink-0
                    <%= user.role==='superadmin' ? 'bg-yellow-500/20 text-yellow-400' : user.role==='admin' ? 'bg-blue-500/20 text-blue-400' : 'bg-purple-500/20 text-purple-400' %>">
                    <%= user.name.charAt(0).toUpperCase() %>
                  </div>
                  <div>
                    <div class="font-semibold text-white">
                      <%= user.name %>
                      <% if (user._id.toString() === currentUser.id) { %><span class="ml-1 text-xs text-yellow-400">(you)</span><% } %>
                    </div>
                    <div class="text-gray-500 text-xs">@<%= user.username %></div>
                  </div>
                </div>
              </td>

              <!-- Role -->
              <td class="px-5 py-4 hidden md:table-cell">
                <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold
                  <%= user.role==='superadmin' ? 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/25' : user.role==='admin' ? 'bg-blue-500/10 text-blue-400 border border-blue-500/25' : 'bg-purple-500/10 text-purple-400 border border-purple-500/25' %>">
                  <%= user.role==='superadmin' ? '⭐ Super Admin' : user.role==='admin' ? '🔧 Admin' : '👁 Viewer' %>
                </span>
              </td>

              <!-- Permissions -->
              <td class="px-5 py-4 hidden lg:table-cell">
                <% if (user.role==='superadmin') { %>
                  <span class="text-yellow-400/70 text-xs">All permissions</span>
                <% } else {
                  const adminDef = {canViewDashboard:true,canViewReports:true,canManageMasters:true,canExportData:true,canManageUsers:false,canViewAlerts:false};
                  const permLabels = {canViewDashboard:'Dashboard',canViewReports:'Reports',canManageMasters:'Master Data',canExportData:'Export',canManageUsers:'Users',canViewAlerts:'Alerts'};
                %>
                  <div class="flex flex-wrap gap-1">
                    <% for (const [key, label] of Object.entries(permLabels)) {
                      const hasPerm = user.role==='admin'
                        ? (typeof user.permissions?.[key]==='boolean' ? user.permissions[key] : adminDef[key])
                        : (user.permissions?.[key]===true);
                    %>
                      <% if (hasPerm) { %>
                        <span class="px-1.5 py-0.5 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 rounded text-xs"><%= label %></span>
                      <% } %>
                    <% } %>
                  </div>
                <% } %>
              </td>

              <!-- Engineer Link / Project Restriction -->
              <td class="px-5 py-4 hidden lg:table-cell">
                <% if (user.role === 'superadmin' || user.role === 'admin') { %>
                  <span class="text-gray-600 text-xs">All projects</span>
                <% } else { %>
                  <% if (user.linkedEngineer) { %>
                    <div class="flex items-center gap-1 mb-1">
                      <svg class="w-3 h-3 text-yellow-400/70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                      <span class="text-xs text-yellow-400/80">Linked engineer</span>
                    </div>
                  <% } %>
                  <% if (user.allowedProjects && user.allowedProjects.length > 0) { %>
                    <span class="px-1.5 py-0.5 bg-blue-500/10 text-blue-400 border border-blue-500/20 rounded text-xs"><%= user.allowedProjects.length %> project<%= user.allowedProjects.length > 1 ? 's' : '' %></span>
                  <% } else { %>
                    <span class="text-gray-600 text-xs">All projects</span>
                  <% } %>
                <% } %>
              </td>

              <!-- Status toggle -->
              <td class="px-5 py-4 hidden sm:table-cell">
                <% if (user.role!=='superadmin' && user._id.toString()!==currentUser.id) { %>
                  <button onclick="toggleStatus('<%= user._id %>', this)" data-active="<%= user.isActive %>"
                          class="relative inline-flex h-5 w-9 rounded-full transition-colors duration-200 <%= user.isActive ? 'bg-emerald-500' : 'bg-gray-600' %>">
                    <span class="inline-block h-4 w-4 mt-0.5 rounded-full bg-white shadow transition-transform duration-200 <%= user.isActive ? 'translate-x-4' : 'translate-x-0.5' %>"></span>
                  </button>
                <% } else { %>
                  <span class="text-xs text-gray-600">—</span>
                <% } %>
              </td>

              <!-- Created -->
              <td class="px-5 py-4 hidden lg:table-cell text-gray-500 text-xs">
                <%= new Date(user.createdAt).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}) %>
                <% if (user.createdBy) { %><div class="text-gray-600">by @<%= user.createdBy.username %></div><% } %>
              </td>

              <!-- Actions -->
              <td class="px-5 py-4 text-right">
                <div class="flex items-center justify-end gap-1">
                  <% if (user.role!=='superadmin' || user._id.toString()===currentUser.id) { %>
                    <a href="/admin/users/<%= user._id %>/edit"
                       class="p-2 rounded-lg text-gray-500 hover:text-gold hover:bg-white/5 transition-all" title="Edit">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    </a>
                  <% } %>
                  <% if (user._id.toString()!==currentUser.id && user.role!=='superadmin') { %>
                    <button onclick="confirmDelete('<%= user._id %>','<%= user.username %>')"
                            class="p-2 rounded-lg text-gray-500 hover:text-red-400 hover:bg-red-500/10 transition-all" title="Delete">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    </button>
                  <% } %>
                </div>
              </td>
            </tr>
            <% } %>
            <% if (users.length===0) { %>
              <tr><td colspan="6" class="px-5 py-12 text-center text-gray-600">No users found.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
  </main>

  <!-- Delete Modal -->
  <div id="deleteModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm">
    <div class="panel p-6 w-full max-w-sm mx-4 shadow-2xl">
      <h3 class="text-lg font-bold text-white mb-2">Delete User</h3>
      <p class="text-gray-400 text-sm mb-6">Delete <span id="deleteUsername" class="text-white font-semibold"></span>? This cannot be undone.</p>
      <div class="flex gap-3">
        <button onclick="closeDeleteModal()" class="flex-1 px-4 py-2.5 rounded-xl border border-white/10 text-gray-300 hover:bg-white/5 text-sm transition-colors">Cancel</button>
        <form id="deleteForm" method="POST" class="flex-1">
          <button type="submit" class="w-full px-4 py-2.5 rounded-xl bg-red-600 hover:bg-red-700 text-white text-sm font-semibold transition-colors">Delete</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Flash auto-hide
    setTimeout(() => {
      document.querySelectorAll('#flash-success,#flash-error').forEach(el => {
        el.style.transition='opacity 0.5s ease'; el.style.opacity='0';
        setTimeout(()=>el.remove(),500);
      });
    }, 4000);

    function toggleStatus(userId, btn) {
      fetch(`/admin/users/${userId}/toggle`,{method:'PATCH',headers:{'Content-Type':'application/json'}})
        .then(r=>r.json()).then(data=>{
          if(data.success){
            btn.dataset.active=data.isActive;
            btn.style.background=data.isActive?'#10b981':'#4b5563';
            const dot=btn.querySelector('span');
            dot.style.transform=data.isActive?'translateX(16px)':'translateX(2px)';
          } else { alert(data.error||'Failed'); }
        });
    }
    function confirmDelete(userId,username){
      document.getElementById('deleteUsername').textContent='@'+username;
      document.getElementById('deleteForm').action=`/admin/users/${userId}/delete`;
      document.getElementById('deleteModal').classList.remove('hidden');
    }
    function closeDeleteModal(){ document.getElementById('deleteModal').classList.add('hidden'); }
  </script>
</body>
</html>
