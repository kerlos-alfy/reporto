<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/logo.png">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/images/logo.png">
<link rel="apple-touch-icon" href="/assets/images/logo.png">
  <title>Add New User — Agile Prime</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            base: { 950:'#080a10', 900:'#0c1017', 850:'#10151f', 800:'#151c28', 700:'#1e2738', 600:'#2a3548' },
            gold: { DEFAULT:'#c9a84c', light:'#e2c97e', dim:'#8a7230' },
          },
          fontFamily: { sans:['DM Sans','system-ui','sans-serif'], mono:['JetBrains Mono','monospace'] },
        },
      },
    };
  </script>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { background:#080a10; color:#c8cdd6; font-family:'DM Sans',system-ui,sans-serif; -webkit-font-smoothing:antialiased; }
    ::-webkit-scrollbar { width:5px; } ::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.08); border-radius:99px; }
    .panel { background:#10151f; border:1px solid rgba(255,255,255,0.06); border-radius:16px; }
    .field { width:100%; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:10px 14px; color:#e2e8f0; font-size:14px; font-family:'DM Sans',sans-serif; outline:none; transition:border-color 0.2s; }
    .field:focus { border-color:rgba(212,168,67,0.4); box-shadow:0 0 0 3px rgba(212,168,67,0.08); }
    .field::placeholder { color:#4b5563; }
    label.role-card input[type=radio] { display:none; }
    label.role-card div { border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:16px; text-align:center; transition:all 0.2s; cursor:pointer; }
    label.role-card input[type=radio]:checked + div { border-color:rgba(212,168,67,0.5); background:rgba(212,168,67,0.08); }
    label.role-card div:hover { border-color:rgba(255,255,255,0.15); }
    .toggle-wrap { display:flex; align-items:center; justify-content:space-between; padding:14px 20px; transition:background 0.15s; }
    .toggle-wrap:hover { background:rgba(255,255,255,0.02); }
    .toggle { position:relative; width:40px; height:20px; }
    .toggle input { display:none; }
    .toggle-slider { position:absolute; inset:0; background:#374151; border-radius:99px; transition:background 0.2s; cursor:pointer; }
    .toggle-slider:before { content:''; position:absolute; width:16px; height:16px; top:2px; left:2px; background:white; border-radius:50%; transition:transform 0.2s; }
    .toggle input:checked + .toggle-slider { background:#c9a84c; }
    .toggle input:checked + .toggle-slider:before { transform:translateX(20px); }
  </style>
</head>
<body class="min-h-screen">

  <%- include('../../partials/navbar') %>

  <% if (typeof flash !== 'undefined' && flash.error) { %>
    <div id="flash-error" class="fixed top-20 right-4 z-50 max-w-sm bg-red-600/90 backdrop-blur-md text-white px-5 py-3 rounded-xl shadow-2xl text-sm font-medium border border-white/10"><%= flash.error %></div>
  <% } %>

  <main class="pt-20 sm:pt-[88px]">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-8">

    <!-- Header -->
    <div class="flex items-center gap-4 mb-8">
      <a href="/admin/users" class="p-2 rounded-xl text-gray-500 hover:text-white hover:bg-white/5 transition-all">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <div>
        <h1 class="text-2xl font-bold text-white">Add New User</h1>
        <p class="text-gray-500 text-sm">Create a user with role and permissions</p>
      </div>
    </div>

    <form action="/admin/users" method="POST">
      <div class="panel p-6 space-y-6 mb-5">

        <!-- Name + Username -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Full Name <span class="text-red-400">*</span></label>
            <input type="text" name="name" value="<%= formData.name||'' %>" required placeholder="e.g. Mohamed Al Farsi" class="field">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Username <span class="text-red-400">*</span></label>
            <div class="relative">
              <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-500 text-sm">@</span>
              <input type="text" name="username" value="<%= formData.username||'' %>" required placeholder="username" class="field" style="padding-left:28px">
            </div>
          </div>
        </div>

        <!-- Email -->
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Email Address</label>
          <input type="email" name="email" value="<%= formData.email||'' %>" placeholder="user@agileprime.ae" class="field">
        </div>

        <!-- Password -->
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Password <span class="text-red-400">*</span></label>
          <input type="password" name="password" required minlength="8" placeholder="Min 8 characters" class="field">
        </div>

        <!-- Role -->
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-3">Role <span class="text-red-400">*</span></label>
          <div class="grid grid-cols-3 gap-3">
            <label class="role-card">
              <input type="radio" name="role" value="superadmin" onchange="onRoleChange('superadmin')">
              <div><div class="text-2xl mb-1">⭐</div><div class="text-sm font-semibold text-white">Super Admin</div><div class="text-xs text-gray-500 mt-1">Full control</div></div>
            </label>
            <label class="role-card">
              <input type="radio" name="role" value="admin" checked onchange="onRoleChange('admin')">
              <div><div class="text-2xl mb-1">🔧</div><div class="text-sm font-semibold text-white">Admin</div><div class="text-xs text-gray-500 mt-1">Reports & data</div></div>
            </label>
            <label class="role-card">
              <input type="radio" name="role" value="viewer" onchange="onRoleChange('viewer')">
              <div><div class="text-2xl mb-1">👁</div><div class="text-sm font-semibold text-white">Viewer</div><div class="text-xs text-gray-500 mt-1">Read-only</div></div>
            </label>
          </div>
        </div>

        <!-- Permissions -->
        <div id="permsSection">
          <label class="block text-sm font-medium text-gray-300 mb-3">Permissions</label>
          <div class="panel divide-y divide-white/5" style="border-radius:12px">
            <div class="toggle-wrap"><div><div class="text-sm font-medium text-white">View Dashboard</div><div class="text-xs text-gray-500">Access the admin dashboard</div></div><label class="toggle"><input type="checkbox" name="permissions[canViewDashboard]" value="on" checked><span class="toggle-slider"></span></label></div>
            <div class="toggle-wrap"><div><div class="text-sm font-medium text-white">View Reports</div><div class="text-xs text-gray-500">View and search daily reports</div></div><label class="toggle"><input type="checkbox" name="permissions[canViewReports]" value="on" checked><span class="toggle-slider"></span></label></div>
            <div class="toggle-wrap"><div><div class="text-sm font-medium text-white">Reports List Page</div><div class="text-xs text-gray-500">Access /admin/reports — browse, search and delete reports</div></div><label class="toggle"><input type="checkbox" name="permissions[canViewReportsList]" value="on"><span class="toggle-slider"></span></label></div>
            <div class="toggle-wrap"><div><div class="text-sm font-medium text-white">Edit Reports</div><div class="text-xs text-gray-500">Edit submitted daily reports</div></div><label class="toggle"><input type="checkbox" name="permissions[canEditReports]" value="on"><span class="toggle-slider"></span></label></div>
            <div class="toggle-wrap"><div><div class="text-sm font-medium text-white">Manage Master Data</div><div class="text-xs text-gray-500">Add/edit projects, engineers, items</div></div><label class="toggle"><input type="checkbox" name="permissions[canManageMasters]" value="on" checked><span class="toggle-slider"></span></label></div>
            <div class="toggle-wrap"><div><div class="text-sm font-medium text-white">Export Data</div><div class="text-xs text-gray-500">Export reports to Excel/PDF</div></div><label class="toggle"><input type="checkbox" name="permissions[canExportData]" value="on" checked><span class="toggle-slider"></span></label></div>
            <div class="toggle-wrap"><div><div class="text-sm font-medium text-white">Manage Users</div><div class="text-xs text-gray-500">Add and edit system users</div></div><label class="toggle"><input type="checkbox" name="permissions[canManageUsers]" value="on"><span class="toggle-slider"></span></label></div>
            <div class="toggle-wrap"><div><div class="text-sm font-medium text-white">View Missing Reports Alert</div><div class="text-xs text-gray-500">See daily alert when engineers haven't submitted reports</div></div><label class="toggle"><input type="checkbox" name="permissions[canViewAlerts]" value="on"><span class="toggle-slider"></span></label></div>
            <div class="toggle-wrap"><div><div class="text-sm font-medium text-white">View Manpower Summary</div><div class="text-xs text-gray-500">Access the per-site daily manpower breakdown page</div></div><label class="toggle"><input type="checkbox" name="permissions[canViewManpowerSummary]" value="on"><span class="toggle-slider"></span></label></div>
          </div>
        </div>

        <!-- Engineer Link & Project Access -->
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Engineer Account Link</label>
          <p class="text-xs text-gray-500 mb-3">When set, the report form will auto-fill and lock the engineer field for this user.</p>
          <select name="linkedEngineer" class="ag-select" style="background-color:#0d1528;color:#e2e8f0">
            <option value="">— No link (user selects manually) —</option>
            <% engineers.forEach(e => { %>
            <option value="<%= e._id %>"><%= e.name %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Project Access Restriction</label>
          <p class="text-xs text-gray-500 mb-3">Leave all unchecked to allow access to all projects. Check specific projects to restrict this user.</p>
          <div class="panel divide-y divide-white/5" style="border-radius:12px; max-height:220px; overflow-y:auto;">
            <% if (projects.length === 0) { %>
              <div class="px-4 py-3 text-xs text-gray-500">No active projects found.</div>
            <% } else { %>
              <% projects.forEach(p => { %>
              <label class="toggle-wrap cursor-pointer hover:bg-white/3 transition-colors">
                <div>
                  <div class="text-sm font-medium text-white"><%= p.name %></div>
                  <% if (p.code) { %><div class="text-xs text-gray-500"><%= p.code %></div><% } %>
                </div>
                <label class="toggle"><input type="checkbox" name="allowedProjects" value="<%= p._id %>"><span class="toggle-slider"></span></label>
              </label>
              <% }) %>
            <% } %>
          </div>
        </div>

      </div>

      <div class="flex gap-3 justify-end">
        <a href="/admin/users" class="px-5 py-2.5 rounded-xl border border-white/10 text-gray-400 hover:bg-white/5 text-sm transition-colors">Cancel</a>
        <button type="submit" class="px-6 py-2.5 rounded-xl font-semibold text-sm transition-all shadow-lg" style="background:#c9a84c;color:#080a10">Create User</button>
      </div>
    </form>

  </div>
  </main>

  <script>
    function onRoleChange(role) {
      document.getElementById('permsSection').style.display = role==='superadmin' ? 'none' : 'block';
    }
    setTimeout(()=>{
      document.querySelectorAll('#flash-error').forEach(el=>{el.style.transition='opacity 0.5s';el.style.opacity='0';setTimeout(()=>el.remove(),500);});
    },4000);
  </script>
</body>
</html>
