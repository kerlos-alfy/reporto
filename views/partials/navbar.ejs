<%
  /* ─── helpers (available in every branch) ─── */
  const _isEng   = typeof adminUser !== 'undefined' && adminUser && !!adminUser.linkedEngineer;
  const _isAdmin = typeof adminUser !== 'undefined' && adminUser &&
                   (adminUser.role === 'superadmin' || adminUser.role === 'admin');

  const _defaults = {
    canViewDashboard: true, canViewReports: true, canViewReportsList: false,
    canManageMasters: true, canExportData: true,
    canManageUsers: false,  canViewAlerts: false,
    canViewManpowerSummary: true, canSubmitReports: false,
  };

  function _can(perm) {
    if (!adminUser) return false;
    if (adminUser.role === 'superadmin') return true;
    if (adminUser.role === 'admin') {
      const ex = adminUser.permissions && typeof adminUser.permissions[perm] === 'boolean'
        ? adminUser.permissions[perm] : undefined;
      return ex !== undefined ? ex : (_defaults[perm] || false);
    }
    return !!(adminUser.permissions && adminUser.permissions[perm]);
  }

  /* current path for active-link highlight */
  const _path = typeof locals !== 'undefined' && locals.currentPath
    ? locals.currentPath
    : (typeof req !== 'undefined' ? req.path : '');
  function _active(href) {
    return _path === href || _path.startsWith(href + '/') ? 'nav-active' : '';
  }
%>

<!-- ═══════════════════════════════════════════
     STYLES  (injected once)
════════════════════════════════════════════ -->
<style>
/* ── base nav ── */
#ag-navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 50;
  height: 60px;
  background: rgba(8,15,35,0.92);
  backdrop-filter: blur(20px) saturate(160%);
  border-bottom: 1px solid rgba(255,255,255,0.07);
  box-shadow: 0 2px 24px rgba(0,0,0,0.35);
  display: flex; align-items: center;
  padding: 0 16px;
  transition: background .3s;
}
#ag-navbar .nav-inner {
  width: 100%; max-width: 1320px; margin: 0 auto;
  display: flex; align-items: center; gap: 8px;
}

/* ── logo ── */
#ag-navbar .nav-logo {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none; flex-shrink: 0;
  margin-right: 4px;
}
#ag-navbar .nav-logo img { height: 36px; width: auto; object-fit: contain; }
#ag-navbar .nav-logo-text {
  font-size: 13px; font-weight: 600;
  color: rgba(255,255,255,0.85); letter-spacing: .03em;
  white-space: nowrap;
}
#ag-navbar .nav-logo-text strong { color: var(--accent, #C9A84C); }

/* ── desktop links ── */
.nav-links {
  display: flex; align-items: center; gap: 2px;
  flex: 1; overflow: hidden;
}
.nav-links a {
  display: flex; align-items: center; gap: 6px;
  font-size: 12.5px; font-weight: 500;
  color: rgba(200,210,230,0.75);
  padding: 7px 11px; border-radius: 8px;
  white-space: nowrap; text-decoration: none;
  border: 1px solid transparent;
  transition: color .18s, background .18s, border-color .18s;
  position: relative;
}
.nav-links a:hover {
  color: #fff;
  background: rgba(255,255,255,0.06);
}
.nav-links a.nav-active {
  color: var(--accent, #C9A84C);
  background: rgba(201,168,76,0.09);
  border-color: rgba(201,168,76,0.18);
}
.nav-links a.nav-users {
  color: rgba(201,168,76,0.8);
  border-color: rgba(201,168,76,0.22);
}
.nav-links a.nav-users:hover { background: rgba(201,168,76,0.1); color: var(--accent,#C9A84C); }
.nav-links a svg { flex-shrink: 0; }

/* ── divider ── */
.nav-divider { width: 1px; height: 28px; background: rgba(255,255,255,0.08); margin: 0 4px; flex-shrink:0; }

/* ── right cluster ── */
.nav-right {
  display: flex; align-items: center; gap: 8px;
  flex-shrink: 0; margin-left: 8px;
}
.nav-user-info {
  display: flex; flex-direction: column; align-items: flex-end;
  line-height: 1.2;
}
.nav-user-info .name  { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.85); }
.nav-user-info .role  { font-size: 10px; color: rgba(160,175,200,0.6); text-transform: capitalize; }

/* ── theme switcher ── */
.ag-theme-switcher { position: relative; }
.ag-theme-btn {
  display: flex; align-items: center; justify-content: center;
  width: 34px; height: 34px; border-radius: 9px; cursor: pointer;
  background: var(--accent-a08, rgba(201,168,76,0.08));
  border: 1px solid var(--accent-a15, rgba(201,168,76,0.15));
  transition: background .18s, border-color .18s;
}
.ag-theme-btn:hover { background: rgba(201,168,76,0.15); }
.ag-theme-panel {
  position: absolute; top: calc(100% + 8px); right: 0;
  background: rgba(10,18,42,0.98); backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;
  padding: 6px; display: flex; gap: 6px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  z-index: 200;
  animation: fadeDown .18s ease;
}
.ag-theme-panel.hidden { display: none; }
@keyframes fadeDown { from { opacity:0; transform:translateY(-6px) } to { opacity:1; transform:none } }
.ag-theme-swatch {
  width: 28px; height: 28px; border-radius: 7px; border: 2px solid transparent;
  cursor: pointer; position: relative; overflow: hidden; transition: border-color .15s;
}
.ag-theme-swatch[data-t="navy"]  { background: linear-gradient(135deg, #0d1b3e 50%, #C9A84C 50%); }
.ag-theme-swatch[data-t="cyan"]  { background: linear-gradient(135deg, #0d2535 50%, #00c4d4 50%); }
.ag-theme-swatch[data-t="amber"] { background: linear-gradient(135deg, #1e1000 50%, #f59e0b 50%); }
.ag-theme-swatch:hover, .ag-theme-swatch.active { border-color: rgba(255,255,255,0.5); }
.ag-theme-swatch::after {
  content: attr(data-label);
  position: absolute; bottom: -22px; left: 50%; transform: translateX(-50%);
  background: rgba(10,18,42,0.95); color: #fff; font-size: 10px;
  padding: 2px 6px; border-radius: 4px; white-space: nowrap;
  opacity: 0; transition: opacity .15s;
  pointer-events: none;
}
.ag-theme-swatch:hover::after { opacity: 1; }

/* ── logout btn ── */
.nav-logout {
  display: flex; align-items: center; gap: 5px;
  font-size: 12px; color: rgba(248,113,113,0.65);
  padding: 7px 10px; border-radius: 8px; cursor: pointer;
  border: 1px solid transparent; background: none;
  transition: color .18s, background .18s;
}
.nav-logout:hover { color: #f87171; background: rgba(239,68,68,0.08); }

/* ════════════════════════════════════════
   MOBILE  (< 1024 px)
════════════════════════════════════════ */
@media (max-width: 1023px) {
  #ag-navbar { height: 56px; }
  .nav-links, .nav-divider, .nav-user-info { display: none !important; }
  .nav-right { gap: 6px; }
}

/* hamburger */
.nav-ham {
  display: none;
  align-items: center; justify-content: center;
  width: 36px; height: 36px; border-radius: 9px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  cursor: pointer; color: rgba(220,225,235,0.8);
  transition: background .18s, color .18s;
}
.nav-ham:hover { background: rgba(255,255,255,0.1); color: #fff; }
@media (max-width:1023px) { .nav-ham { display: flex; } }

/* ── mobile drawer ── */
#ag-drawer {
  position: fixed;
  top: 56px; left: 0; right: 0; bottom: 0;
  z-index: 49;
  display: flex; flex-direction: column;
  background: rgba(7,13,32,0.97);
  backdrop-filter: blur(24px);
  transform: translateX(100%);
  transition: transform .28s cubic-bezier(.4,0,.2,1);
  overflow-y: auto;
  padding: 12px 16px 40px;
  gap: 4px;
}
#ag-drawer.open { transform: translateX(0); }

/* drawer user badge */
.drawer-user {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 12px; margin-bottom: 6px;
  background: rgba(255,255,255,0.04);
  border-radius: 12px; border: 1px solid rgba(255,255,255,0.07);
}
.drawer-avatar {
  width: 40px; height: 40px; border-radius: 10px;
  background: linear-gradient(135deg, rgba(201,168,76,0.2), rgba(201,168,76,0.05));
  border: 1px solid rgba(201,168,76,0.25);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; font-weight: 700; color: var(--accent,#C9A84C);
  flex-shrink: 0;
}
.drawer-user-info .dname { font-size: 14px; font-weight: 600; color: #fff; }
.drawer-user-info .drole { font-size: 11px; color: rgba(160,175,200,0.6); text-transform: capitalize; margin-top: 1px; }

/* drawer links */
.drawer-link {
  display: flex; align-items: center; gap: 12px;
  font-size: 14px; font-weight: 500;
  color: rgba(200,210,230,0.75);
  padding: 12px 14px; border-radius: 10px;
  text-decoration: none; border: 1px solid transparent;
  transition: background .15s, color .15s, border-color .15s;
}
.drawer-link:hover, .drawer-link:active {
  color: #fff; background: rgba(255,255,255,0.07);
}
.drawer-link.nav-active {
  color: var(--accent,#C9A84C);
  background: rgba(201,168,76,0.08);
  border-color: rgba(201,168,76,0.18);
}
.drawer-link.nav-users {
  color: rgba(201,168,76,0.85);
  border-color: rgba(201,168,76,0.2);
  margin-top: 4px;
}
.drawer-link svg { flex-shrink: 0; opacity: .8; }
.drawer-link.nav-active svg, .drawer-link:hover svg { opacity: 1; }

/* section label inside drawer */
.drawer-section {
  font-size: 10px; font-weight: 700; letter-spacing: .1em;
  text-transform: uppercase; color: rgba(160,175,200,0.35);
  padding: 10px 14px 4px;
}

/* drawer separator */
.drawer-sep { height: 1px; background: rgba(255,255,255,0.07); margin: 6px 0; }

/* drawer logout */
.drawer-logout {
  display: flex; align-items: center; gap: 12px;
  font-size: 14px; font-weight: 500;
  color: rgba(248,113,113,0.7);
  padding: 12px 14px; border-radius: 10px;
  border: none; background: none; cursor: pointer; width: 100%;
  transition: background .15s, color .15s;
}
.drawer-logout:hover { color: #f87171; background: rgba(239,68,68,0.08); }

/* overlay */
#ag-drawer-overlay {
  position: fixed; inset: 0; z-index: 48;
  background: rgba(0,0,0,0.5);
  opacity: 0; pointer-events: none;
  transition: opacity .28s;
}
#ag-drawer-overlay.open { opacity: 1; pointer-events: all; }

/* scrollbar in drawer */
#ag-drawer::-webkit-scrollbar { width: 4px; }
#ag-drawer::-webkit-scrollbar-track { background: transparent; }
#ag-drawer::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
</style>

