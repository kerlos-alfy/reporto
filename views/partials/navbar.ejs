        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Workforce
      </a>
      <% if (_can('canViewManpowerSummary')) { %>
        <a href="/admin/manpower-summary" class="drawer-link <%= _active('/admin/manpower-summary') %>" onclick="agCloseDrawer()">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          MP Summary
        </a>
        <a href="/admin/manpower-breakdown" class="drawer-link <%= _active('/admin/manpower-breakdown') %>" onclick="agCloseDrawer()">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
          MP Breakdown
        </a>
      <% } %>
    <% } %>

    <% if (_can('canManageMasters')) { %>
      <div class="drawer-section">Configuration</div>
      <a href="/admin/master-data" class="drawer-link <%= _active('/admin/master-data') %>" onclick="agCloseDrawer()">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93A10 10 0 1 0 4.93 19.07 10 10 0 0 0 19.07 4.93z"/></svg>
        Master Data
      </a>
    <% } %>

    <% if (adminUser.role === 'superadmin' || _can('canManageUsers')) { %>
      <a href="/admin/users" class="drawer-link nav-users <%= _active('/admin/users') %>" onclick="agCloseDrawer()">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        Users
      </a>
    <% } %>

  <% } %>

  <div class="drawer-sep" style="margin-top:auto"></div>

  <!-- Logout -->
  <form action="/admin/logout" method="POST">
    <button type="submit" class="drawer-logout">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Sign Out
    </button>
  </form>

</aside>
<% } %>

<!-- ═══════════════════════════════════════════
     SCRIPTS
════════════════════════════════════════════ -->
<script>
(function () {
  /* ── Drawer ── */
  function agOpenDrawer() {
    const d  = document.getElementById('ag-drawer');
    const ov = document.getElementById('ag-drawer-overlay');
    const btn = document.getElementById('ag-ham-btn');
    if (!d) return;
    d.classList.add('open');
    ov && ov.classList.add('open');
    document.body.style.overflow = 'hidden';
    document.getElementById('ag-icon-ham').style.display = 'none';
    document.getElementById('ag-icon-x').style.display   = '';
    btn && btn.setAttribute('aria-expanded', 'true');
  }
  function agCloseDrawer() {
    const d  = document.getElementById('ag-drawer');
    const ov = document.getElementById('ag-drawer-overlay');
    const btn = document.getElementById('ag-ham-btn');
    if (!d) return;
    d.classList.remove('open');
    ov && ov.classList.remove('open');
    document.body.style.overflow = '';
    document.getElementById('ag-icon-ham').style.display = '';
    document.getElementById('ag-icon-x').style.display   = 'none';
    btn && btn.setAttribute('aria-expanded', 'false');
  }
  window.agToggleDrawer = function () {
    const d = document.getElementById('ag-drawer');
    d && d.classList.contains('open') ? agCloseDrawer() : agOpenDrawer();
  };
  window.agCloseDrawer = agCloseDrawer;

  /* Close on Escape */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') agCloseDrawer();
  });

  /* ── Theme panel ── */
  window.agToggleTheme = function (e) {
    e.stopPropagation();
    ['ag-theme-panel'].forEach(function (id) {
      const p = document.getElementById(id);
      if (p) p.classList.toggle('hidden');
    });
  };
  document.addEventListener('click', function () {
    document.getElementById('ag-theme-panel')?.classList.add('hidden');
  });

  /* ── Active swatch highlight ── */
  function markActiveSwatch(theme) {
    document.querySelectorAll('.ag-theme-swatch').forEach(function (s) {
      s.classList.toggle('active', s.dataset.t === theme);
    });
  }
  const currentTheme = document.documentElement.dataset.theme || localStorage.getItem('ag-theme') || 'navy';
  markActiveSwatch(currentTheme);

  /* ── Scroll shadow ── */
  window.addEventListener('scroll', function () {
    const nav = document.getElementById('ag-navbar');
    if (!nav) return;
    if (window.scrollY > 10) {
      nav.style.background = 'rgba(6,12,28,0.97)';
      nav.style.boxShadow  = '0 2px 32px rgba(0,0,0,0.5)';
    } else {
      nav.style.background = 'rgba(8,15,35,0.92)';
      nav.style.boxShadow  = '0 2px 24px rgba(0,0,0,0.35)';
    }
  }, { passive: true });
})();
</script>
